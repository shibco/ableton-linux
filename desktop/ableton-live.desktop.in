[Desktop Entry]
Name=@NAME@
Comment=Music production (Wine, patched d2d1-dcomp stack)
Exec=@HOME@/.local/bin/ableton-live %f
Type=Application
StartupNotify=true
Path=@HOME@/.wine-ableton
Icon=@ICON@
StartupWMClass=@WMCLASS@
MimeType=application/x-ableton-live-set;application/x-ableton-live-clip;application/x-ableton-live-pack;
Categories=AudioVideo;Audio;
