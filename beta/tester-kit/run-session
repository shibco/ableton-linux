#!/usr/bin/env bash
set -uo pipefail

umask 077

KIT_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$KIT_ROOT/lib/common.sh"
source "$KIT_ROOT/lib/collect-linux.sh"
source "$KIT_ROOT/lib/fetch-installer.sh"
source "$KIT_ROOT/lib/run-probes.sh"

PREFIX="${ABLETON_WINEPREFIX:-$HOME/.wine-ableton}"
OUTPUT_DIR="${ABLETON_BETA_OUTPUT_DIR:-$PWD}"
INSTALLER_URL="${ABLETON_BETA_INSTALLER_URL:-}"
INSTALLER_SHA256="${ABLETON_BETA_INSTALLER_SHA256:-}"
WINE_BIN="${ABLETON_BETA_WINE:-}"
SKIP_INSTALLER=0
ALLOW_UNVERIFIED_INSTALLER=0
REUSE_PREFIX=0
LIVE_PROBES=0
LIVE_ONLY=0
ADVANCED_INPUT=0
NON_INTERACTIVE=0
QUICK=0
KEEP_WORK=0
LIST_ONLY=0
BACKGROUND_PIDS=()

usage() {
    cat <<'EOF'
Usage: ./tester-kit/run-session [options]

Default flow:
  create ~/.wine-ableton, collect a redacted Linux report, download and verify
  the Para-Repos installer, initialise its Wine build, run regression probes,
  and write session-YYYY-MM-DD-HHMMSS.txt.

Options:
  --output-dir DIR             Directory for the final session text file
  --prefix DIR                 Test prefix; default ~/.wine-ableton
  --reuse-prefix               Permit a non-empty existing prefix
  --installer-url URL          Override the provisional Para-Repos URL
  --installer-sha256 SHA256    Expected installer hash
  --allow-unverified-installer Run a downloaded installer without a checksum
  --skip-installer             Do not download or run the installer
  --wine PATH                  Wine binary to test; required with --skip-installer
  --live-probes                Add passive probes while Ableton Live is running
  --live-only                  Run only host readiness and passive Live probes
  --advanced-input-trace       Add an explicitly confirmed global Wine input trace
  --non-interactive            Skip tests that need visual confirmation
  --quick                      Use 5,000 rather than 30,000 stress iterations
  --keep-work                  Keep the private temporary evidence directory
  --list                       List the test set without changing anything
  -h, --help                   Show this help

The default installer URL is read from tester-kit/config/installer-url.
The installer is not executed unless its SHA-256 is verified, unless the
tester deliberately supplies --allow-unverified-installer.
EOF
}

list_tests() {
    cat <<'EOF'
W00  Runtime startup and fresh-prefix initialisation
H01  WirePlumber session-manager readiness
H02  PipeWire-Pulse graph readiness
T01  Shared-session allocator stress
T02  Pop-up menu creation
T03  Live-style menu/resize convergence
T03M Raw DPI and non-client metrics
T04  OpenGL child context and sRGB pixel format
T05  Plug-in title bars and layered shadows, visual
T06  XDG portal file dialogue, visual
T07  Virtual MIDI controller replug
C01  DPI, file-dialogue and audio-driver policy snapshot
C02  Nested audio endpoint FriendlyName guard
L01-L12 Optional passive and manual Live-session probes
A01  Optional global Wine mouse and JUCE input trace
EOF
}

while (($#)); do
    case "$1" in
        --output-dir)
            [[ $# -ge 2 ]] || { printf 'Missing value for --output-dir\n' >&2; exit 64; }
            OUTPUT_DIR="$2"; shift 2 ;;
        --prefix)
            [[ $# -ge 2 ]] || { printf 'Missing value for --prefix\n' >&2; exit 64; }
            PREFIX="$2"; shift 2 ;;
        --reuse-prefix) REUSE_PREFIX=1; shift ;;
        --installer-url)
            [[ $# -ge 2 ]] || { printf 'Missing value for --installer-url\n' >&2; exit 64; }
            INSTALLER_URL="$2"; shift 2 ;;
        --installer-sha256)
            [[ $# -ge 2 ]] || { printf 'Missing value for --installer-sha256\n' >&2; exit 64; }
            INSTALLER_SHA256="$2"; shift 2 ;;
        --allow-unverified-installer) ALLOW_UNVERIFIED_INSTALLER=1; shift ;;
        --skip-installer) SKIP_INSTALLER=1; shift ;;
        --wine)
            [[ $# -ge 2 ]] || { printf 'Missing value for --wine\n' >&2; exit 64; }
            WINE_BIN="$2"; shift 2 ;;
        --live-probes) LIVE_PROBES=1; shift ;;
        --live-only) LIVE_ONLY=1; LIVE_PROBES=1; SKIP_INSTALLER=1; REUSE_PREFIX=1; shift ;;
        --advanced-input-trace) ADVANCED_INPUT=1; LIVE_PROBES=1; shift ;;
        --non-interactive) NON_INTERACTIVE=1; shift ;;
        --quick) QUICK=1; shift ;;
        --keep-work) KEEP_WORK=1; shift ;;
        --list) LIST_ONLY=1; shift ;;
        -h|--help) usage; exit 0 ;;
        *) printf 'Unknown option: %s\n' "$1" >&2; usage >&2; exit 64 ;;
    esac
done

if [[ $LIST_ONLY == 1 ]]; then
    list_tests
    exit 0
fi

if [[ -z "$INSTALLER_URL" && -r "$KIT_ROOT/config/installer-url" ]]; then
    INSTALLER_URL="$(head -n 1 "$KIT_ROOT/config/installer-url")"
fi

mkdir -p "$OUTPUT_DIR"
STAMP="$(date '+%Y-%m-%d-%H%M%S')"
SESSION_FILE="$OUTPUT_DIR/session-$STAMP.txt"
if [[ -e "$SESSION_FILE" ]]; then
    SESSION_FILE="$OUTPUT_DIR/session-$STAMP-$$.txt"
fi

WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ableton-beta-session.XXXXXXXX")"
RESULTS_FILE="$WORK_DIR/results.tsv"
: > "$RESULTS_FILE"

TESTER_ID="$(load_tester_id)" || {
    printf 'Could not create the Tester-ID.\n' >&2
    exit 69
}
MACHINE_ID="$(load_machine_id)"
export TESTER_ID MACHINE_ID

cleanup() {
    local pid
    for pid in "${BACKGROUND_PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
    done
    if [[ -n ${MOUSESPY_BACKUP:-} && -f ${MOUSESPY_BACKUP:-} ]]; then
        mv -- "$MOUSESPY_BACKUP" /tmp/mousespy.txt 2>/dev/null || true
    fi
    if [[ ${KEEP_WORK:-0} == 0 && -n ${WORK_DIR:-} && -d ${WORK_DIR:-} ]]; then
        rm -rf -- "$WORK_DIR"
    elif [[ -n ${WORK_DIR:-} && -d ${WORK_DIR:-} ]]; then
        printf 'Private temporary evidence retained at: %s\n' "$WORK_DIR"
    fi
}
trap cleanup EXIT INT TERM HUP

exec > >(redact_stream | tee -a "$SESSION_FILE") 2>&1

section "ABLETON WINE BETA SESSION"
printf 'Session file: %s\n' "$SESSION_FILE"
printf 'Started UTC: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
printf 'Started local: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')"
printf 'Tester kit: %s\n' "$KIT_ROOT"
printf 'Tester-ID: %s\n' "$TESTER_ID"
printf 'Machine-ID: %s\n' "$MACHINE_ID"
printf 'Requested prefix: %s\n' "$PREFIX"

section "PREFIX PREPARATION"
if [[ ! -e "$PREFIX" ]]; then
    mkdir -m 700 -p "$PREFIX"
    printf 'Created empty prefix directory: %s\n' "$PREFIX"
elif [[ ! -d "$PREFIX" ]]; then
    record_result SETUP FAIL "Prefix path is a directory" "$PREFIX exists but is not a directory"
    printf 'Cannot continue. Session report remains at %s\n' "$SESSION_FILE"
    exit 73
elif find "$PREFIX" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
    if [[ $REUSE_PREFIX != 1 ]]; then
        record_result SETUP FAIL "Fresh or explicitly approved prefix" "non-empty prefix refused"
        printf 'The prefix already contains files. This kit will not alter it without --reuse-prefix.\n'
        printf 'Use a new test account, move the old prefix safely, or rerun deliberately with --reuse-prefix.\n'
        exit 73
    fi
    printf 'WARNING: reusing a non-empty prefix by explicit request.\n'
else
    chmod 700 "$PREFIX" 2>/dev/null || true
    printf 'Using existing empty prefix directory: %s\n' "$PREFIX"
fi
record_result SETUP PASS "Prefix directory prepared" "$PREFIX"

collect_linux_report 2>&1 | redact_stream

if [[ $SKIP_INSTALLER == 0 ]]; then
    section "PARA-REPOS INSTALLER"
    if [[ -z "$INSTALLER_URL" ]]; then
        record_result INSTALLER FAIL "Installer URL configured" "no URL supplied"
        exit 69
    fi
    INSTALLER_PATH="$WORK_DIR/wine-ableton-installer.sh"
    if ! fetch_and_verify_installer "$INSTALLER_URL" "$INSTALLER_PATH" "$INSTALLER_SHA256"; then
        record_result INSTALLER FAIL "Installer fetched and verified" "$INSTALLER_URL"
        printf 'The system report is complete, but no unverified remote code was run.\n'
        exit 69
    fi
    record_result INSTALLER PASS "Installer fetched and verified" "$INSTALLER_ACTUAL_SHA256"

    subsection "Run installer"
    printf 'The installer receives ABLETON_WINEPREFIX and WINEPREFIX set to the prepared directory.\n'
    ABLETON_WINEPREFIX="$PREFIX" WINEPREFIX="$PREFIX" ABLETON_BETA_SESSION=1 bash "$INSTALLER_PATH"
    installer_rc=$?
    if [[ $installer_rc -ne 0 ]]; then
        record_result INSTALLER-RUN FAIL "Installer completed" "exit $installer_rc"
        exit "$installer_rc"
    fi
    record_result INSTALLER-RUN PASS "Installer completed" "exit 0"
else
    section "INSTALLER SKIPPED"
    printf 'Installer download and execution were deliberately skipped.\n'
    record_result INSTALLER SKIP "Installer fetched and run" "developer override"
fi

discover_wine() {
    local candidate
    local -a candidates=()

    [[ -n "$WINE_BIN" ]] && candidates+=("$WINE_BIN")
    candidates+=(
        "$HOME/.local/opt/ableton-wine/current/bin/wine"
        "$HOME/.local/opt/wine-d2d1-nspa-11.13/bin/wine"
    )
    if [[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/ableton-wine/runtime-path" ]]; then
        candidate="$(head -n 1 "${XDG_CONFIG_HOME:-$HOME/.config}/ableton-wine/runtime-path")"
        candidates+=("$candidate/bin/wine")
    fi

    for candidate in "${candidates[@]}"; do
        if [[ -x "$candidate" ]]; then
            WINE_BIN="$(readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate")"
            return 0
        fi
    done
    return 1
}

section "RUNTIME DISCOVERY"
if ! discover_wine; then
    record_result RUNTIME FAIL "Installed patched Wine found" "use --wine or install patched Wine first"
    exit 69
fi
WINE_ROOT="$(cd -- "$(dirname -- "$WINE_BIN")/.." && pwd -P)"
WINESERVER_BIN="$WINE_ROOT/bin/wineserver"
WINEBOOT_BIN="$WINE_ROOT/bin/wineboot"
if [[ ! -x "$WINESERVER_BIN" || ! -x "$WINEBOOT_BIN" ]]; then
    record_result RUNTIME FAIL "Matched Wine support binaries found" "$WINE_ROOT"
    exit 69
fi

unset WINELOADER WINEDLLPATH WINEDLLOVERRIDES WINEARCH WINEESYNC WINEFSYNC WINE_FORCE_PORTAL
export WINEPREFIX="$PREFIX"
export WINESERVER="$WINESERVER_BIN"
export PATH="$WINE_ROOT/bin:$PATH"
export WINEDEBUG=-all

WINDOWS_PROBES="$KIT_ROOT/probes/windows"
NATIVE_SOURCES="$KIT_ROOT/probes/src"
ADVANCED_WINDOWS="$KIT_ROOT/probes/advanced/windows"
export WINDOWS_PROBES NATIVE_SOURCES ADVANCED_WINDOWS

if ! (cd "$KIT_ROOT/probes" && sha256sum -c SHA256SUMS); then
    record_result PROBES FAIL "Probe checksums verified" "tester kit may be damaged"
    exit 65
fi
record_result PROBES PASS "Probe checksums verified" "all distributed executables"
if ! (cd "$KIT_ROOT/probes/advanced" && sha256sum -c SHA256SUMS); then
    record_result ADVANCED-PROBES FAIL "Advanced probe checksums verified" "tester kit may be damaged"
    exit 65
fi
record_result ADVANCED-PROBES PASS "Advanced probe checksums verified" "all optional executables"

if [[ $LIVE_ONLY == 1 ]]; then
    section "LIVE-ONLY RUNTIME"
    printf 'Wine binary: %s\nWine version: %s\nPrefix: %s\n' "$WINE_BIN" "$("$WINE_BIN" --version 2>&1 || true)" "$PREFIX"
    record_result W00 INFO "Existing runtime selected without wineboot" "live-only mode"
    test_audio_readiness
    run_live_probes
    if [[ $ADVANCED_INPUT == 1 ]]; then
        run_advanced_input_trace
    fi
else
    run_probe_suite
fi

section "RESULT SUMMARY"
printf '%-16s %-8s %-48s %s\n' "ID" "STATUS" "CHECK" "DETAIL"
printf '%-16s %-8s %-48s %s\n' "----------------" "--------" "------------------------------------------------" "------"
awk -F '\t' '{printf "%-16s %-8s %-48s %s\n", $1, $2, $3, $4}' "$RESULTS_FILE"
printf '\nPass: %s  Fail: %s  Warn: %s  Review: %s  Skip: %s  Info: %s\n' "$(status_count PASS)" "$(status_count FAIL)" "$(status_count WARN)" "$(status_count REVIEW)" "$(status_count SKIP)" "$(status_count INFO)"

section "PRIVACY AND NEXT STEP"
printf '%s\n' 'The collector omits unique hardware identifiers, common home paths, MAC addresses, credential-like lines and captured window titles.' 'If an excluded value appears, keep the session local and report the collector failure instead of editing the session by hand.' 'Do not add Ableton licence files, installers, projects, samples or plug-in credentials.' 'File one issue per FAIL and attach the unchanged session file.'
printf 'Completed UTC: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
printf 'Session complete: %s\n' "$SESSION_FILE"

if (( $(status_count FAIL) > 0 )); then
    exit 1
fi
exit 0
