#!/usr/bin/env bash
# Ableton Live 12 Beta launcher — isolated prefix, existing patched Wine stack.
set -u

WINE_ROOT="${ABLETON_WINE_ROOT:-$HOME/.local/opt/wine-d2d1-nspa-11.11}"
export WINEPREFIX="${ABLETON_BETA_WINEPREFIX:-$HOME/.wine-ableton-beta}"
export PATH="$WINE_ROOT/bin:$PATH"
export WINEDEBUG="${WINEDEBUG:--all}"
export WINE_D3D_CONFIG="${WINE_D3D_CONFIG:-csmt=0x1}"
export WINED3D_DCOMP_FORCE_FULL_REDRAW="${WINED3D_DCOMP_FORCE_FULL_REDRAW:-1}"
# Report host mount points as plain dirs (patch 0033); Live's browser treats
# junctions without reparse data as unresolvable and skips them.
export WINE_DISABLE_UNIX_MOUNT_REPARSE="${WINE_DISABLE_UNIX_MOUNT_REPARSE:-1}"
export WINESERVER="$WINE_ROOT/bin/wineserver"

if pgrep -af 'Ableton Live 12 Suite[.]exe' 2>/dev/null | grep -q 'ProgramData'; then
    echo "Ableton Live 12 Suite is running; close it before launching the beta." >&2
    exit 75
fi

if ! pgrep -af 'Ableton Live 12 Beta[.]exe' 2>/dev/null | grep -q 'ProgramData'; then
    "$WINE_ROOT/bin/wineserver" -k 2>/dev/null || true
    /usr/bin/wineserver -k 2>/dev/null || true
fi

# Audio: PipeASIO -> PipeWire (native client). Defaults come from
# ~/.config/pipeasio/config.ini; PIPEASIO_* variables override per launch.

EXE='C:\ProgramData\Ableton\Live 12 Beta\Program\Ableton Live 12 Beta.exe'

run=(wine)
if command -v chrt >/dev/null 2>&1 && chrt -r 10 true >/dev/null 2>&1; then
    run=(chrt -r 10 wine)
fi

if [ -n "${ABLETON_VDESK:-}" ]; then
    exec "${run[@]}" explorer "/desktop=AbletonLive12Beta,${ABLETON_VDESK}" "$EXE"
elif [ "$#" -gt 0 ]; then
    exec "${run[@]}" start "$@"
else
    exec "${run[@]}" "$EXE"
fi
