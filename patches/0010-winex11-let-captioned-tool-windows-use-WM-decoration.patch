From c1483990bebcb7d4e71a8af99ef0771cda7bf478 Mon Sep 17 00:00:00 2001
From: dist <build@localhost>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 10/41] winex11: let captioned tool windows use WM decorations
 at high DPI

Request MWM decorations for tool windows that carry a real caption, so the WM
draws their frame. Caption-less tool windows are unaffected.
---
 dlls/winex11.drv/window.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/dlls/winex11.drv/window.c b/dlls/winex11.drv/window.c
index 92e611fa..109b1067 100644
--- a/dlls/winex11.drv/window.c
+++ b/dlls/winex11.drv/window.c
@@ -500,7 +500,13 @@ static unsigned long get_mwm_decorations_for_style( DWORD style, DWORD ex_style
 {
     unsigned long ret = 0;
 
-    if (ex_style & WS_EX_TOOLWINDOW) return 0;
+    /* Tool windows (WS_EX_TOOLWINDOW) normally suppress WM decorations so Wine draws its
+     * own small caption. But at 192 DPI that Wine-drawn caption is oversized (Ableton's
+     * VST plugin editors are WS_EX_TOOLWINDOW|WS_CAPTION -> a huge title bar). If the tool
+     * window has a real caption, let mutter decorate it instead: the WM frame is drawn at
+     * the compositor scale, so it matches the main window's native GNOME title bar.
+     * Caption-less tool windows (tooltips etc.) still fall through to ret=0 below. */
+    if ((ex_style & WS_EX_TOOLWINDOW) && (style & WS_CAPTION) != WS_CAPTION) return 0;
 
     if ((style & WS_CAPTION) == WS_CAPTION)
     {
