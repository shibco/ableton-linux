+
+/***********************************************************************
+ *              __wine_portal_show_item (COMDLG32.@)
+ *
+ * Reveal a file or directory in the host file browser through the XDG
+ * OpenURI portal. Returns FALSE when the portal policy, the platform or
+ * the portal itself rules it out; the caller keeps its explorer fallback.
+ */
+BOOL CDECL __wine_portal_show_item(const WCHAR *path)
+{
+    struct portal_open_directory_params params;
+    const char *force_portal = getenv("WINE_FORCE_PORTAL");
+    WCHAR policy[32];
+    char *unix_path;
+    size_t len;
+    NTSTATUS status;
+
+    TRACE("%s\n", debugstr_w(path));
+
+    if (!path || !*path) return FALSE;
+
+    /* FileDialogPortal=never turns off all portal integration; there is no
+     * per-call eligibility to check for a plain reveal request. */
+    if (!(force_portal && *force_portal == '1') &&
+        wine_get_appdefaults_reg_sz(L"X11 Driver", L"FileDialogPortal", policy, sizeof(policy)) &&
+        !wcsicmp(policy, L"never"))
+    {
+        TRACE("portal disabled by policy\n");
+        return FALSE;
+    }
+
+    if (!__wine_unixlib_handle)
+    {
+        TRACE("no portal unix library (32-bit caller?)\n");
+        return FALSE;
+    }
+
+    unix_path = wine_get_unix_file_name(path);
+    if (!unix_path) return FALSE;
+
+    memset(&params, 0, sizeof(params));
+    len = strlen(unix_path);
+    if (len >= sizeof(params.path_unix))
+    {
+        HeapFree(GetProcessHeap(), 0, unix_path);
+        return FALSE;
+    }
+    memcpy(params.path_unix, unix_path, len + 1);
+    HeapFree(GetProcessHeap(), 0, unix_path);
+
+    status = WINE_UNIX_CALL(unix_portal_open_directory, &params);
+    TRACE("%s -> %#lx\n", debugstr_w(path), (unsigned long)status);
+    return !status;
+}
