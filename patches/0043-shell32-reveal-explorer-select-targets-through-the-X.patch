 dlls/comdlg32/unixlib.c     |  9 ++++-
 dlls/comdlg32/unixlib.h     |  6 +++
 dlls/shell32/shlexec.c      | 79 +++++++++++++++++++++++++++++++++++++
 6 files changed, 230 insertions(+), 1 deletion(-)

