From aa1c670fd14438511bb516e0db5f90cd332d17a6 Mon Sep 17 00:00:00 2001
From: dist <build@localhost>
Date: Tue, 21 Jul 2026 17:45:45 -0230
Subject: [PATCH] configure: fix libusb-1.0 detection check against 11.13's
 AC_CHECK_FUNC switch

The Push2 bridge's build-gate (0031: builds dlls/libusb-1.0 only when the
host actually has libusb-1.0) checked ac_cv_lib_usb_1_0_libusb_interrupt_event_handler,
which is only set when configure detects libusb-1.0 via AC_CHECK_LIB.
Upstream switched this exact check from AC_CHECK_LIB to AC_CHECK_FUNC
between 11.11 and 11.13 (producing ac_cv_func_libusb_interrupt_event_handler
instead) -- 0031's added lines sat right after this block in both
configure.ac and the generated configure script with no textual overlap,
so the rebase carried them through unconflicted while silently checking
a cache variable configure never sets under the new macro. Always-true,
so enable_libusb_1_0 was unconditionally forced to no: dlls/libusb-1.0's
libusb-1.0.dll never got built. Fixed in BOTH files this patch touches
(container-build.sh runs the pre-generated ./configure directly, never
autoreconf -- a configure.ac-only fix is a no-op at build time; the
generated configure script is what actually needs to be correct).
---
 configure    | 2 +-
 configure.ac | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/configure b/configure
index c76787b9..7799c7f7 100755
--- a/configure
+++ b/configure
@@ -17830,7 +17830,7 @@ This is an error since --with-usb was requested." "$LINENO" 5 ;;
 esac
 enable_wineusb_sys=${enable_wineusb_sys:-no}
 fi
-if test "$ac_cv_lib_usb_1_0_libusb_interrupt_event_handler" != "yes"
+if test "$ac_cv_func_libusb_interrupt_event_handler" != "yes"
 then :
   enable_libusb_1_0=no
 fi
diff --git a/configure.ac b/configure.ac
index 5297a4f8..d33b7463 100644
--- a/configure.ac
+++ b/configure.ac
@@ -1609,7 +1609,7 @@ fi
 WINE_NOTICE_WITH(usb,[test "$ac_cv_func_libusb_interrupt_event_handler" != "yes"],
                  [libusb-1.0 ${notice_platform}development files not found (or too old), USB devices won't be supported.],
                  [enable_wineusb_sys])
-AS_IF([test "$ac_cv_lib_usb_1_0_libusb_interrupt_event_handler" != "yes"],
+AS_IF([test "$ac_cv_func_libusb_interrupt_event_handler" != "yes"],
       [enable_libusb_1_0=no])
 
 dnl **** Check for libv4l2 ****
