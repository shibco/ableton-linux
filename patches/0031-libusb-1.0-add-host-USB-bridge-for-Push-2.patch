+ * License along with this library; if not, write to the Free Software
+ * Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA 02110-1301, USA
+ */
+
+#include <stdarg.h>
+#include <stddef.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+
+#define WIN32_NO_STATUS
+#include "windef.h"
+#include "winbase.h"
+#include "winternl.h"
+#include "winuser.h"
+#undef WIN32_NO_STATUS
+#include "ntstatus.h"
+#include "ntuser.h"
+
+#include "wine/debug.h"
+#include "wine/unixlib.h"
+
+#include "unixlib.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(libusb);
+
+/* Force user32 to initialize the kernel callback table before this DLL attaches. */
+void *libusb_user32_import = GetDesktopWindow;
+
+enum libusb_error
+{
+    LIBUSB_SUCCESS = 0,
+    LIBUSB_ERROR_IO = -1,
+    LIBUSB_ERROR_INVALID_PARAM = -2,
+    LIBUSB_ERROR_ACCESS = -3,
+    LIBUSB_ERROR_NO_DEVICE = -4,
+    LIBUSB_ERROR_NOT_FOUND = -5,
+    LIBUSB_ERROR_BUSY = -6,
+    LIBUSB_ERROR_TIMEOUT = -7,
+    LIBUSB_ERROR_OVERFLOW = -8,
+    LIBUSB_ERROR_PIPE = -9,
+    LIBUSB_ERROR_INTERRUPTED = -10,
+    LIBUSB_ERROR_NO_MEM = -11,
+    LIBUSB_ERROR_NOT_SUPPORTED = -12,
+    LIBUSB_ERROR_OTHER = -99,
+};
+
+enum libusb_transfer_status
+{
+    LIBUSB_TRANSFER_COMPLETED,
+    LIBUSB_TRANSFER_ERROR,
+    LIBUSB_TRANSFER_TIMED_OUT,
+    LIBUSB_TRANSFER_CANCELLED,
+    LIBUSB_TRANSFER_STALL,
+    LIBUSB_TRANSFER_NO_DEVICE,
+    LIBUSB_TRANSFER_OVERFLOW,
+};
+
+#define LIBUSB_TRANSFER_TYPE_BULK 2
+#define LIBUSB_OPTION_LOG_LEVEL 0
+
+struct libusb_context
+{
+    UINT64 native;
+};
+
+struct libusb_device
+{
+    UINT64 native;
+};
+
+struct libusb_device_handle
+{
+    UINT64 native;
+};
+
+struct libusb_device_descriptor
+{
+    UINT8 bLength;
+    UINT8 bDescriptorType;
+    UINT16 bcdUSB;
+    UINT8 bDeviceClass;
+    UINT8 bDeviceSubClass;
+    UINT8 bDeviceProtocol;
+    UINT8 bMaxPacketSize0;
+    UINT16 idVendor;
+    UINT16 idProduct;
+    UINT16 bcdDevice;
+    UINT8 iManufacturer;
+    UINT8 iProduct;
+    UINT8 iSerialNumber;
+    UINT8 bNumConfigurations;
+};
+
+struct libusb_iso_packet_descriptor
+{
+    UINT32 length;
+    UINT32 actual_length;
+    enum libusb_transfer_status status;
+};
+
+struct libusb_transfer;
+typedef void (WINAPI *libusb_transfer_cb_fn)(struct libusb_transfer *transfer);
+
+struct libusb_transfer
+{
+    struct libusb_device_handle *dev_handle;
+    UINT8 flags;
+    UINT8 endpoint;
+    UINT8 type;
+    UINT32 timeout;
+    enum libusb_transfer_status status;
+    INT32 length;
+    INT32 actual_length;
+    libusb_transfer_cb_fn callback;
+    void *user_data;
+    UINT8 *buffer;
+    INT32 num_iso_packets;
+    struct libusb_iso_packet_descriptor iso_packet_desc[0];
+};
+
+struct libusb_timeval
+{
+    INT32 tv_sec;
+    INT32 tv_usec;
+};
+
+struct libusb_device_list
+{
+    UINT64 native;
+    SSIZE_T count;
+    struct libusb_device *devices[];
+};
+
+struct libusb_transfer_wrapper
+{
+    UINT64 native;
+    struct libusb_transfer transfer;
+};
+
+C_ASSERT(sizeof(struct libusb_device) == sizeof(UINT64));
+C_ASSERT(sizeof(struct libusb_device_descriptor) == 18);
+C_ASSERT(sizeof(struct libusb_device_descriptor_abi) == 18);
+C_ASSERT(offsetof(struct libusb_device_descriptor, bDeviceClass) == 4);
+C_ASSERT(offsetof(struct libusb_device_descriptor, idVendor) == 8);
+C_ASSERT(offsetof(struct libusb_device_descriptor, idProduct) == 10);
+C_ASSERT(sizeof(struct libusb_iso_packet_descriptor) == 12);
+C_ASSERT(sizeof(struct libusb_transfer) == 64);
+C_ASSERT(offsetof(struct libusb_transfer, dev_handle) == 0);
+C_ASSERT(offsetof(struct libusb_transfer, flags) == 8);
+C_ASSERT(offsetof(struct libusb_transfer, endpoint) == 9);
+C_ASSERT(offsetof(struct libusb_transfer, type) == 10);
+C_ASSERT(offsetof(struct libusb_transfer, timeout) == 12);
+C_ASSERT(offsetof(struct libusb_transfer, status) == 16);
+C_ASSERT(offsetof(struct libusb_transfer, length) == 20);
+C_ASSERT(offsetof(struct libusb_transfer, actual_length) == 24);
+C_ASSERT(offsetof(struct libusb_transfer, callback) == 32);
+C_ASSERT(offsetof(struct libusb_transfer, user_data) == 40);
+C_ASSERT(offsetof(struct libusb_transfer, buffer) == 48);
+C_ASSERT(offsetof(struct libusb_transfer, num_iso_packets) == 56);
+C_ASSERT(offsetof(struct libusb_transfer, iso_packet_desc) == 60);
+C_ASSERT(sizeof(struct libusb_timeval) == 8);
+
+static struct libusb_transfer_wrapper *impl_from_transfer(struct libusb_transfer *transfer)
+{
+    return CONTAINING_RECORD(transfer, struct libusb_transfer_wrapper, transfer);
+}
+
+static UINT64 context_handle(struct libusb_context *context)
+{
+    return context ? context->native : 0;
+}
+
+static int unix_call_failed(NTSTATUS status, const char *name)
+{
+    if (!status) return FALSE;
+    ERR("%s unix call failed, status %#lx\n", name, status);
+    return TRUE;
+}
+
+static NTSTATUS WINAPI call_transfer_callback(void *args, ULONG size)
+{
+    const struct libusb_transfer_callback_params *params = args;
+    struct libusb_transfer *transfer;
+    libusb_transfer_cb_fn callback;
+
+    if (size != sizeof(*params)) return STATUS_INFO_LENGTH_MISMATCH;
+    if (!(transfer = (void *)(UINT_PTR)params->transfer)) return STATUS_INVALID_PARAMETER;
+
+    callback = (void *)(UINT_PTR)params->callback;
+    transfer->status = params->status;
+    transfer->actual_length = params->actual_length;
+    if (callback) callback(transfer);
+
+    /* The callback may have freed or resubmitted transfer. */
+    return STATUS_SUCCESS;
+}
+
+int WINAPI libusb_init(struct libusb_context **context)
+{
+    struct libusb_init_params params = {0};
+    struct libusb_context *wrapper = NULL;
+    NTSTATUS status;
+
+    TRACE("%p\n", context);
+
+    if (context)
+    {
+        *context = NULL;
+        if (!(wrapper = calloc(1, sizeof(*wrapper)))) return LIBUSB_ERROR_NO_MEM;
+        params.want_context = TRUE;
+    }
+
+    status = UNIX_CALL(libusb_init, &params);
+    if (unix_call_failed(status, "libusb_init")) params.result = LIBUSB_ERROR_OTHER;
+    if (params.result < 0)
+    {
+        free(wrapper);
+        return params.result;
+    }
+
+    if (context)
+    {
+        wrapper->native = params.context;
+        *context = wrapper;
+    }
+    return params.result;
+}
+
+void WINAPI libusb_exit(struct libusb_context *context)
+{
+    struct libusb_exit_params params = {context_handle(context)};
+
+    TRACE("%p\n", context);
+    unix_call_failed(UNIX_CALL(libusb_exit, &params), "libusb_exit");
+    free(context);
+}
+
+int WINAPIV libusb_set_option(struct libusb_context *context, int option, ...)
+{
+    struct libusb_set_option_params params = {0};
+    va_list args;
+    NTSTATUS status;
+
+    TRACE("%p, %d\n", context, option);
+
+    if (option != LIBUSB_OPTION_LOG_LEVEL) return LIBUSB_ERROR_NOT_SUPPORTED;
+
+    va_start(args, option);
+    params.value = va_arg(args, int);
+    va_end(args);
+
+    params.context = context_handle(context);
+    params.option = option;
+    status = UNIX_CALL(libusb_set_option, &params);
+    if (unix_call_failed(status, "libusb_set_option")) return LIBUSB_ERROR_OTHER;
+    return params.result;
+}
+
+SSIZE_T WINAPI libusb_get_device_list(struct libusb_context *context, struct libusb_device ***list)
+{
+    struct libusb_get_device_list_params get_params = {context_handle(context)};
+    struct libusb_copy_device_list_params copy_params = {0};
+    struct libusb_free_device_list_params free_params;
+    struct libusb_device_list *owner;
+    struct libusb_device *devices;
+    SIZE_T count, size;
+    NTSTATUS status;
+    unsigned int i;
+
+    TRACE("%p, %p\n", context, list);
+
+    if (!list) return LIBUSB_ERROR_INVALID_PARAM;
+    *list = NULL;
+
+    status = UNIX_CALL(libusb_get_device_list, &get_params);
+    if (unix_call_failed(status, "libusb_get_device_list")) return LIBUSB_ERROR_OTHER;
+    if (get_params.result < 0) return get_params.result;
+    if (!get_params.list) return LIBUSB_ERROR_OTHER;
+
+    count = get_params.result;
+    if (count > (SIZE_MAX - offsetof(struct libusb_device_list, devices) - sizeof(void *)) /
+                (sizeof(void *) + sizeof(struct libusb_device)))
+    {
+        free_params.list = get_params.list;
+        free_params.unref_devices = TRUE;
+        UNIX_CALL(libusb_free_device_list, &free_params);
+        return LIBUSB_ERROR_NO_MEM;
+    }
+
+    size = offsetof(struct libusb_device_list, devices) + (count + 1) * sizeof(void *) +
+           count * sizeof(struct libusb_device);
+    if (!(owner = calloc(1, size)))
+    {
+        free_params.list = get_params.list;
+        free_params.unref_devices = TRUE;
+        UNIX_CALL(libusb_free_device_list, &free_params);
+        return LIBUSB_ERROR_NO_MEM;
+    }
+
+    owner->native = get_params.list;
+    owner->count = count;
+    devices = (struct libusb_device *)(owner->devices + count + 1);
+
+    copy_params.list = owner->native;
+    copy_params.devices = (UINT_PTR)devices;
+    copy_params.count = count;
+    status = UNIX_CALL(libusb_copy_device_list, &copy_params);
+    if (unix_call_failed(status, "libusb_copy_device_list")) copy_params.result = LIBUSB_ERROR_OTHER;
+    if (copy_params.result < 0)
+    {
+        free_params.list = owner->native;
+        free_params.unref_devices = TRUE;
+        UNIX_CALL(libusb_free_device_list, &free_params);
+        free(owner);
+        return copy_params.result;
+    }
+
+    for (i = 0; i < count; ++i) owner->devices[i] = &devices[i];
+    owner->devices[count] = NULL;
+    *list = owner->devices;
+    return count;
+}
+
+void WINAPI libusb_free_device_list(struct libusb_device **list, int unref_devices)
+{
+    struct libusb_device_list *owner;
+    struct libusb_free_device_list_params params;
+
+    TRACE("%p, %d\n", list, unref_devices);
+    if (!list) return;
+
+    owner = CONTAINING_RECORD(list, struct libusb_device_list, devices);
+    params.list = owner->native;
+    params.unref_devices = unref_devices;
+    unix_call_failed(UNIX_CALL(libusb_free_device_list, &params), "libusb_free_device_list");
+    free(owner);
+}
+
+int WINAPI libusb_get_device_descriptor(struct libusb_device *device,
+                                        struct libusb_device_descriptor *descriptor)
+{
+    struct libusb_get_device_descriptor_params params = {0};
+    NTSTATUS status;
+
+    TRACE("%p, %p\n", device, descriptor);
+    if (!device || !descriptor) return LIBUSB_ERROR_INVALID_PARAM;
+
+    params.device = device->native;
+    status = UNIX_CALL(libusb_get_device_descriptor, &params);
+    if (unix_call_failed(status, "libusb_get_device_descriptor")) return LIBUSB_ERROR_OTHER;
+    if (!params.result) memcpy(descriptor, &params.descriptor, sizeof(*descriptor));
+    return params.result;
+}
+
+int WINAPI libusb_open(struct libusb_device *device, struct libusb_device_handle **handle)
+{
+    struct libusb_device_handle *wrapper;
+    struct libusb_open_params params = {0};
+    NTSTATUS status;
+
+    TRACE("%p, %p\n", device, handle);
+    if (!device || !handle) return LIBUSB_ERROR_INVALID_PARAM;
+    *handle = NULL;
+    if (!(wrapper = calloc(1, sizeof(*wrapper)))) return LIBUSB_ERROR_NO_MEM;
+
+    params.device = device->native;
+    status = UNIX_CALL(libusb_open, &params);
+    if (unix_call_failed(status, "libusb_open")) params.result = LIBUSB_ERROR_OTHER;
+    if (params.result < 0)
+    {
+        free(wrapper);
+        return params.result;
+    }
+
+    wrapper->native = params.handle;
+    *handle = wrapper;
+    return params.result;
+}
+
+void WINAPI libusb_close(struct libusb_device_handle *handle)
+{
+    struct libusb_close_params params;
+
+    TRACE("%p\n", handle);
+    if (!handle) return;
+    params.handle = handle->native;
+    unix_call_failed(UNIX_CALL(libusb_close, &params), "libusb_close");
+    free(handle);
+}
+
+static int interface_operation(struct libusb_device_handle *handle, int interface_number,
+                               enum libusb_unix_funcs func, const char *name)
+{
+    struct libusb_interface_params params = {0};
+    NTSTATUS status;
+
+    if (!handle || interface_number != 0) return LIBUSB_ERROR_INVALID_PARAM;
+    params.handle = handle->native;
+    params.interface_number = interface_number;
+    status = WINE_UNIX_CALL(func, &params);
+    if (unix_call_failed(status, name)) return LIBUSB_ERROR_OTHER;
+    return params.result;
+}
+
+int WINAPI libusb_claim_interface(struct libusb_device_handle *handle, int interface_number)
+{
+    TRACE("%p, %d\n", handle, interface_number);
+    return interface_operation(handle, interface_number, unix_libusb_claim_interface,
+                               "libusb_claim_interface");
+}
+
+int WINAPI libusb_release_interface(struct libusb_device_handle *handle, int interface_number)
+{
+    TRACE("%p, %d\n", handle, interface_number);
+    return interface_operation(handle, interface_number, unix_libusb_release_interface,
+                               "libusb_release_interface");
+}
+
+struct libusb_transfer * WINAPI libusb_alloc_transfer(int iso_packets)
+{
+    struct libusb_alloc_transfer_params params = {0};
+    struct libusb_transfer_wrapper *wrapper;
+    SIZE_T size;
+    NTSTATUS status;
+
+    TRACE("%d\n", iso_packets);
+    if (iso_packets < 0) return NULL;
+    if ((SIZE_T)iso_packets > (SIZE_MAX - sizeof(*wrapper)) /
+                              sizeof(struct libusb_iso_packet_descriptor))
+        return NULL;
+
+    size = sizeof(*wrapper) + (SIZE_T)iso_packets * sizeof(struct libusb_iso_packet_descriptor);
+    if (!(wrapper = calloc(1, size))) return NULL;
+
+    params.iso_packets = iso_packets;
+    status = UNIX_CALL(libusb_alloc_transfer, &params);
+    if (unix_call_failed(status, "libusb_alloc_transfer") || params.result < 0)
+    {
+        free(wrapper);
+        return NULL;
+    }
+
+    wrapper->native = params.transfer;
+    wrapper->transfer.num_iso_packets = iso_packets;
+    return &wrapper->transfer;
+}
+
+void WINAPI libusb_free_transfer(struct libusb_transfer *transfer)
+{
+    struct libusb_transfer_handle_params params = {0};
+    struct libusb_transfer_wrapper *wrapper;
+
+    TRACE("%p\n", transfer);
+    if (!transfer) return;
+
+    wrapper = impl_from_transfer(transfer);
+    params.transfer = wrapper->native;
+    unix_call_failed(UNIX_CALL(libusb_free_transfer, &params), "libusb_free_transfer");
+    free(wrapper);
+}
+
+int WINAPI libusb_submit_transfer(struct libusb_transfer *transfer)
+{
+    struct libusb_submit_transfer_params params = {0};
+    struct libusb_transfer_wrapper *wrapper;
+    NTSTATUS status;
+
+    TRACE("%p\n", transfer);
+    if (!transfer || !transfer->dev_handle) return LIBUSB_ERROR_INVALID_PARAM;
+    if (transfer->type != LIBUSB_TRANSFER_TYPE_BULK || transfer->num_iso_packets != 0 || transfer->flags != 0)
+        return LIBUSB_ERROR_NOT_SUPPORTED;
+    if (transfer->length < 0 || (transfer->length && !transfer->buffer))
+        return LIBUSB_ERROR_INVALID_PARAM;
+
+    wrapper = impl_from_transfer(transfer);
+    params.transfer = wrapper->native;
+    params.handle = transfer->dev_handle->native;
+    params.client_transfer = (UINT_PTR)transfer;
+    params.client_callback = (UINT_PTR)transfer->callback;
+    params.buffer = (UINT_PTR)transfer->buffer;
+    params.timeout = transfer->timeout;
+    params.length = transfer->length;
+    params.num_iso_packets = transfer->num_iso_packets;
+    params.flags = transfer->flags;
+    params.endpoint = transfer->endpoint;
+    params.type = transfer->type;
+
+    status = UNIX_CALL(libusb_submit_transfer, &params);
+    if (unix_call_failed(status, "libusb_submit_transfer")) return LIBUSB_ERROR_OTHER;
+    return params.result;
+}
+
+int WINAPI libusb_cancel_transfer(struct libusb_transfer *transfer)
+{
+    struct libusb_transfer_handle_params params = {0};
+    struct libusb_transfer_wrapper *wrapper;
+    NTSTATUS status;
+
+    TRACE("%p\n", transfer);
+    if (!transfer) return LIBUSB_ERROR_INVALID_PARAM;
+
+    wrapper = impl_from_transfer(transfer);
+    params.transfer = wrapper->native;
+    status = UNIX_CALL(libusb_cancel_transfer, &params);
+    if (unix_call_failed(status, "libusb_cancel_transfer")) return LIBUSB_ERROR_OTHER;
+    return params.result;
+}
+
+int WINAPI libusb_handle_events_timeout(struct libusb_context *context, const struct libusb_timeval *timeout)
+{
+    struct libusb_handle_events_timeout_params params = {0};
+    NTSTATUS status;
+
+    TRACE("%p, %p\n", context, timeout);
+    if (!timeout) return LIBUSB_ERROR_INVALID_PARAM;
+
+    params.context = context_handle(context);
+    params.seconds = timeout->tv_sec;
+    params.microseconds = timeout->tv_usec;
+    status = UNIX_CALL(libusb_handle_events_timeout, &params);
+    if (unix_call_failed(status, "libusb_handle_events_timeout")) return LIBUSB_ERROR_OTHER;
+    return params.result;
+}
+
+const char * WINAPI libusb_error_name(int error)
+{
+    switch (error)
+    {
+        case LIBUSB_SUCCESS: return "LIBUSB_SUCCESS / LIBUSB_TRANSFER_COMPLETED";
+        case LIBUSB_ERROR_IO: return "LIBUSB_ERROR_IO";
+        case LIBUSB_ERROR_INVALID_PARAM: return "LIBUSB_ERROR_INVALID_PARAM";
+        case LIBUSB_ERROR_ACCESS: return "LIBUSB_ERROR_ACCESS";
+        case LIBUSB_ERROR_NO_DEVICE: return "LIBUSB_ERROR_NO_DEVICE";
+        case LIBUSB_ERROR_NOT_FOUND: return "LIBUSB_ERROR_NOT_FOUND";
+        case LIBUSB_ERROR_BUSY: return "LIBUSB_ERROR_BUSY";
+        case LIBUSB_ERROR_TIMEOUT: return "LIBUSB_ERROR_TIMEOUT";
+        case LIBUSB_ERROR_OVERFLOW: return "LIBUSB_ERROR_OVERFLOW";
+        case LIBUSB_ERROR_PIPE: return "LIBUSB_ERROR_PIPE";
+        case LIBUSB_ERROR_INTERRUPTED: return "LIBUSB_ERROR_INTERRUPTED";
+        case LIBUSB_ERROR_NO_MEM: return "LIBUSB_ERROR_NO_MEM";
+        case LIBUSB_ERROR_NOT_SUPPORTED: return "LIBUSB_ERROR_NOT_SUPPORTED";
+        case LIBUSB_ERROR_OTHER: return "LIBUSB_ERROR_OTHER";
+        default: return "LIBUSB_ERROR_OTHER";
+    }
+}
+
+BOOL WINAPI DllMain(HINSTANCE instance, DWORD reason, void *reserved)
+{
+    if (reason == DLL_PROCESS_ATTACH)
+    {
+        struct libusb_process_attach_params params = {(UINT_PTR)call_transfer_callback};
+        KERNEL_CALLBACK_PROC *callback_table;
+        NTSTATUS status;
+
+        DisableThreadLibraryCalls(instance);
+
+        callback_table = NtCurrentTeb()->Peb->KernelCallbackTable;
+        if (!callback_table || !callback_table[NtUserCallDispatchCallback])
+        {
+            ERR("user32 callback table is unavailable\n");
+            return FALSE;
+        }
+
+        if ((status = __wine_init_unix_call()) ||
+            (status = UNIX_CALL(process_attach, &params)))
+        {
+            ERR("failed to initialize unixlib, status %#lx\n", status);
+            return FALSE;
+        }
+    }
+    return TRUE;
+}
