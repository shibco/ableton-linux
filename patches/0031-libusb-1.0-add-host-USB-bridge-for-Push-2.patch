+ *
+ * This library is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * Lesser General Public License for more details.
+ *
+ * You should have received a copy of the GNU Lesser General Public
+ * License along with this library; if not, write to the Free Software
+ * Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA 02110-1301, USA
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+#include <libusb.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <sys/time.h>
+
+#include "ntstatus.h"
+#include "windef.h"
+#include "winbase.h"
+#include "winternl.h"
+#include "ntuser.h"
+
+#include "wine/debug.h"
+#include "wine/unixlib.h"
+
+#include "unixlib.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(libusb);
+
+struct native_transfer
+{
+    struct libusb_transfer *host;
+    UINT64 client_transfer;
+    UINT64 client_callback;
+};
+
+static UINT64 transfer_callback;
+
+static libusb_context *context_from_handle(UINT64 handle)
+{
+    return (libusb_context *)(uintptr_t)handle;
+}
+
+static libusb_device *device_from_handle(UINT64 handle)
+{
+    return (libusb_device *)(uintptr_t)handle;
+}
+
+static libusb_device_handle *device_handle_from_handle(UINT64 handle)
+{
+    return (libusb_device_handle *)(uintptr_t)handle;
+}
+
+static struct native_transfer *transfer_from_handle(UINT64 handle)
+{
+    return (struct native_transfer *)(uintptr_t)handle;
+}
+
+static NTSTATUS wrap_process_attach(void *args)
+{
+    const struct libusb_process_attach_params *params = args;
+
+    if (!params->transfer_callback) return STATUS_INVALID_PARAMETER;
+    transfer_callback = params->transfer_callback;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_init(void *args)
+{
+    struct libusb_init_params *params = args;
+    libusb_context *context = NULL;
+
+    if (params->want_context)
+        params->result = libusb_init(&context);
+    else
+        params->result = libusb_init(NULL);
+    params->context = (UINT64)(uintptr_t)context;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_exit(void *args)
+{
+    const struct libusb_exit_params *params = args;
+
+    libusb_exit(context_from_handle(params->context));
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_set_option(void *args)
+{
+    struct libusb_set_option_params *params = args;
+
+    if (params->option != LIBUSB_OPTION_LOG_LEVEL)
+        params->result = LIBUSB_ERROR_NOT_SUPPORTED;
+    else
+        params->result = libusb_set_option(context_from_handle(params->context),
+                                           LIBUSB_OPTION_LOG_LEVEL, params->value);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_get_device_list(void *args)
+{
+    struct libusb_get_device_list_params *params = args;
+    libusb_device **list = NULL;
+    ssize_t count;
+
+    count = libusb_get_device_list(context_from_handle(params->context), &list);
+    params->list = (UINT64)(uintptr_t)list;
+    params->result = count;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_copy_device_list(void *args)
+{
+    struct libusb_copy_device_list_params *params = args;
+    libusb_device **list = (libusb_device **)(uintptr_t)params->list;
+    UINT64 *devices = (UINT64 *)(uintptr_t)params->devices;
+    INT64 i;
+
+    if (!list || !devices || params->count < 0)
+    {
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+        return STATUS_SUCCESS;
+    }
+
+    for (i = 0; i < params->count; ++i)
+    {
+        if (!list[i])
+        {
+            params->result = LIBUSB_ERROR_OTHER;
+            return STATUS_SUCCESS;
+        }
+        devices[i] = (UINT64)(uintptr_t)list[i];
+    }
+    if (list[params->count])
+    {
+        params->result = LIBUSB_ERROR_OTHER;
+        return STATUS_SUCCESS;
+    }
+
+    params->result = LIBUSB_SUCCESS;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_free_device_list(void *args)
+{
+    const struct libusb_free_device_list_params *params = args;
+
+    libusb_free_device_list((libusb_device **)(uintptr_t)params->list, params->unref_devices);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_get_device_descriptor(void *args)
+{
+    struct libusb_get_device_descriptor_params *params = args;
+    struct libusb_device_descriptor descriptor;
+
+    params->result = libusb_get_device_descriptor(device_from_handle(params->device), &descriptor);
+    if (params->result) return STATUS_SUCCESS;
+
+    params->descriptor.bLength = descriptor.bLength;
+    params->descriptor.bDescriptorType = descriptor.bDescriptorType;
+    params->descriptor.bcdUSB = descriptor.bcdUSB;
+    params->descriptor.bDeviceClass = descriptor.bDeviceClass;
+    params->descriptor.bDeviceSubClass = descriptor.bDeviceSubClass;
+    params->descriptor.bDeviceProtocol = descriptor.bDeviceProtocol;
+    params->descriptor.bMaxPacketSize0 = descriptor.bMaxPacketSize0;
+    params->descriptor.idVendor = descriptor.idVendor;
+    params->descriptor.idProduct = descriptor.idProduct;
+    params->descriptor.bcdDevice = descriptor.bcdDevice;
+    params->descriptor.iManufacturer = descriptor.iManufacturer;
+    params->descriptor.iProduct = descriptor.iProduct;
+    params->descriptor.iSerialNumber = descriptor.iSerialNumber;
+    params->descriptor.bNumConfigurations = descriptor.bNumConfigurations;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_open(void *args)
+{
+    struct libusb_open_params *params = args;
+    libusb_device_handle *handle = NULL;
+
+    params->result = libusb_open(device_from_handle(params->device), &handle);
+    params->handle = (UINT64)(uintptr_t)handle;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_close(void *args)
+{
+    const struct libusb_close_params *params = args;
+
+    libusb_close(device_handle_from_handle(params->handle));
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_claim_interface(void *args)
+{
+    struct libusb_interface_params *params = args;
+
+    if (params->interface_number != 0)
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+    else
+        params->result = libusb_claim_interface(device_handle_from_handle(params->handle),
+                                                params->interface_number);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_release_interface(void *args)
+{
+    struct libusb_interface_params *params = args;
+
+    if (params->interface_number != 0)
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+    else
+        params->result = libusb_release_interface(device_handle_from_handle(params->handle),
+                                                  params->interface_number);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_alloc_transfer(void *args)
+{
+    struct libusb_alloc_transfer_params *params = args;
+    struct native_transfer *wrapper;
+
+    params->transfer = 0;
+    if (!(wrapper = calloc(1, sizeof(*wrapper))))
+    {
+        params->result = LIBUSB_ERROR_NO_MEM;
+        return STATUS_SUCCESS;
+    }
+    if (!(wrapper->host = libusb_alloc_transfer(params->iso_packets)))
+    {
+        free(wrapper);
+        params->result = LIBUSB_ERROR_NO_MEM;
+        return STATUS_SUCCESS;
+    }
+
+    params->transfer = (UINT64)(uintptr_t)wrapper;
+    params->result = LIBUSB_SUCCESS;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_free_transfer(void *args)
+{
+    const struct libusb_transfer_handle_params *params = args;
+    struct native_transfer *wrapper = transfer_from_handle(params->transfer);
+
+    if (wrapper)
+    {
+        libusb_free_transfer(wrapper->host);
+        free(wrapper);
+    }
+    return STATUS_SUCCESS;
+}
+
+static void LIBUSB_CALL host_transfer_complete(struct libusb_transfer *host)
+{
+    struct native_transfer *wrapper = host->user_data;
+    struct libusb_transfer_callback_params params;
+    void *ret_ptr = NULL;
+    ULONG ret_len = 0;
+    NTSTATUS status;
+
+    if (!wrapper || !transfer_callback)
+    {
+        ERR("completion lacks callback state\n");
+        return;
+    }
+    if (!NtCurrentTeb())
+    {
+        ERR("completion arrived on a native thread\n");
+        return;
+    }
+
+    params.dispatch.callback = transfer_callback;
+    params.transfer = wrapper->client_transfer;
+    params.callback = wrapper->client_callback;
+    params.status = host->status;
+    params.actual_length = host->actual_length;
+
+    status = KeUserDispatchCallback(&params.dispatch, sizeof(params), &ret_ptr, &ret_len);
+    if (status) ERR("callback dispatch failed, status %#x\n", (unsigned int)status);
+
+    /* The Windows callback may have freed or resubmitted host and wrapper. */
+}
+
+static NTSTATUS wrap_libusb_submit_transfer(void *args)
+{
+    struct libusb_submit_transfer_params *params = args;
+    struct native_transfer *wrapper = transfer_from_handle(params->transfer);
+    struct libusb_transfer *host;
+
+    if (!wrapper || !(host = wrapper->host) || !params->handle || !params->client_transfer ||
+        params->type != LIBUSB_TRANSFER_TYPE_BULK || params->num_iso_packets != 0 || params->flags != 0 ||
+        params->length < 0 || (params->length && !params->buffer))
+    {
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+        return STATUS_SUCCESS;
+    }
+
+    wrapper->client_transfer = params->client_transfer;
+    wrapper->client_callback = params->client_callback;
+    host->dev_handle = device_handle_from_handle(params->handle);
+    host->flags = params->flags;
+    host->endpoint = params->endpoint;
+    host->type = params->type;
+    host->timeout = params->timeout;
+    host->length = params->length;
+    host->callback = host_transfer_complete;
+    host->user_data = wrapper;
+    host->buffer = (unsigned char *)(uintptr_t)params->buffer;
+
+    params->result = libusb_submit_transfer(host);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_cancel_transfer(void *args)
+{
+    struct libusb_transfer_handle_params *params = args;
+    struct native_transfer *wrapper = transfer_from_handle(params->transfer);
+
+    if (!wrapper || !wrapper->host)
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+    else
+        params->result = libusb_cancel_transfer(wrapper->host);
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS wrap_libusb_handle_events_timeout(void *args)
+{
+    struct libusb_handle_events_timeout_params *params = args;
+    struct timeval timeout;
+    INT64 seconds = params->seconds;
+    INT64 microseconds = params->microseconds;
+
+    seconds += microseconds / 1000000;
+    microseconds %= 1000000;
+    if (microseconds < 0)
+    {
+        --seconds;
+        microseconds += 1000000;
+    }
+    if (seconds < 0)
+    {
+        params->result = LIBUSB_ERROR_INVALID_PARAM;
+        return STATUS_SUCCESS;
+    }
+
+    timeout.tv_sec = seconds;
+    timeout.tv_usec = microseconds;
+    params->result = libusb_handle_events_timeout(context_from_handle(params->context), &timeout);
+    return STATUS_SUCCESS;
+}
+
+const unixlib_entry_t __wine_unix_call_funcs[] =
+{
+    [unix_process_attach] = wrap_process_attach,
+    [unix_libusb_init] = wrap_libusb_init,
+    [unix_libusb_exit] = wrap_libusb_exit,
+    [unix_libusb_set_option] = wrap_libusb_set_option,
+    [unix_libusb_get_device_list] = wrap_libusb_get_device_list,
+    [unix_libusb_copy_device_list] = wrap_libusb_copy_device_list,
+    [unix_libusb_free_device_list] = wrap_libusb_free_device_list,
+    [unix_libusb_get_device_descriptor] = wrap_libusb_get_device_descriptor,
+    [unix_libusb_open] = wrap_libusb_open,
+    [unix_libusb_close] = wrap_libusb_close,
+    [unix_libusb_claim_interface] = wrap_libusb_claim_interface,
+    [unix_libusb_release_interface] = wrap_libusb_release_interface,
+    [unix_libusb_alloc_transfer] = wrap_libusb_alloc_transfer,
+    [unix_libusb_free_transfer] = wrap_libusb_free_transfer,
+    [unix_libusb_submit_transfer] = wrap_libusb_submit_transfer,
+    [unix_libusb_cancel_transfer] = wrap_libusb_cancel_transfer,
+    [unix_libusb_handle_events_timeout] = wrap_libusb_handle_events_timeout,
+};
+
+C_ASSERT(ARRAYSIZE(__wine_unix_call_funcs) == unix_funcs_count);
