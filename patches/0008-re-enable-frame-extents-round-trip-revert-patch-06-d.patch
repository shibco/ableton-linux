Subject: re-enable frame-extents round-trip (revert patch 06) +
 drop size clamp (revert patch 07): converge Live window feedback via the real
 WM frame

---
 dlls/win32u/window.c      | 18 ------------------
 dlls/winex11.drv/window.c | 19 ++++++++++---------
 2 files changed, 10 insertions(+), 27 deletions(-)

diff --git a/dlls/win32u/window.c b/dlls/win32u/window.c
index 8d8e3839..755aeed1 100644
--- a/dlls/win32u/window.c
+++ b/dlls/win32u/window.c
@@ -4277,24 +4277,6 @@ BOOL WINAPI NtUserSetWindowPos( HWND hwnd, HWND after, INT x, INT y, INT cx, INT
     winpos.cy = cy;
     winpos.flags = flags;
 
-    /* Bug-57955 anti-growth clamp (Ableton Live on this patched Wine at high DPI):
-     * Live's own resize handler drives the outer window a few pixels larger on every
-     * relayout, overshooting the monitor and never converging (observed: +2px/cycle,
-     * 4096 -> 4108 -> ... forever). Cap a top-level window's requested size to its
-     * monitor, but only when the overshoot is small (the feedback signature) so a
-     * deliberately large resize (e.g. spanning monitors) is left untouched. Size-only:
-     * position and frame geometry are never altered, so the native window feel and any
-     * normal sub-monitor size are unaffected. Done in the app-facing entry (before DPI
-     * mapping) so cx/cy and the monitor rect share the same get_thread_dpi() space. */
-    if (!(flags & SWP_NOSIZE) && !(get_window_long( winpos.hwnd, GWL_STYLE ) & WS_CHILD))
-    {
-        MONITORINFO mi = monitor_info_from_window( winpos.hwnd, MONITOR_DEFAULTTONEAREST );
-        LONG mw = mi.rcMonitor.right - mi.rcMonitor.left;
-        LONG mh = mi.rcMonitor.bottom - mi.rcMonitor.top;
-        if (mw > 0 && winpos.cx > mw && winpos.cx <= mw + 256) winpos.cx = mw;
-        if (mh > 0 && winpos.cy > mh && winpos.cy <= mh + 256) winpos.cy = mh;
-    }
-
     map_dpi_winpos( &winpos );
 
     if (is_current_thread_window( hwnd ))
diff --git a/dlls/winex11.drv/window.c b/dlls/winex11.drv/window.c
index 3c3166f1..8a68045c 100644
--- a/dlls/winex11.drv/window.c
+++ b/dlls/winex11.drv/window.c
@@ -1769,15 +1769,16 @@ BOOL read_net_frame_extents( Display *display, Window window, long *extents )
 
 void window_net_frame_extents_notify( struct x11drv_win_data *data, const long *extents, BOOL valid )
 {
-    /* Frame-extents reconstruction (NSPA 1c) is disabled: feeding the WM's positive
-     * _NET_FRAME_EXTENTS margins into get_visible_rect / window_rect_from_visible_state
-     * (which expect AdjustWindowRect's negative-inset convention) inverts the offset and
-     * shoves standard-decorated windows (comdlg32 file dialogs) off the bottom at high DPI.
-     * Live's own windows are custom-NC (client==window) and never take this path, so
-     * keeping has_frame_extents always FALSE restores stock geometry for decorated windows
-     * without regressing the bug-57955 fixes (custom-NC masking + reentrancy suppression). */
-    data->has_frame_extents = FALSE;
-    memset( data->frame_extents, 0, sizeof(data->frame_extents) );
+    /* Frame-extents reconstruction (NSPA 1c): use the WM's real _NET_FRAME_EXTENTS to
+     * close the window<->visible round-trip exactly, so Live reads back the true frame
+     * instead of AdjustWindowRect's guess and its window-size feedback loop converges
+     * (bug 57955). window_rect_from_visible_state expands by the frame and get_visible_rect
+     * insets by the same frame, so the transform is a consistent identity. */
+    data->has_frame_extents = valid;
+    if (valid)
+        memcpy( data->frame_extents, extents, sizeof(data->frame_extents) );
+    else
+        memset( data->frame_extents, 0, sizeof(data->frame_extents) );
 }
 
 
