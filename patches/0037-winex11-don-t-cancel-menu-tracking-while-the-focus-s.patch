From 9751ea77c170026c540e2566e9a946696c5d293e Mon Sep 17 00:00:00 2001
From: dist <build@localhost>
Date: Thu, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH 37/41] winex11: don't cancel menu tracking while the focus
 stays in the process

Issue #3: Live's Preferences dropdowns are win32u popup menus, mapped as
override-redirect X11 windows. Mapping or clicking one makes GNOME's
mutter and Cinnamon's muffin shuffle the X input focus, and the
resulting NotifyNormal FocusOut reaches the foreground window while the
menu loop is still tracking; focus_out() then sends WM_CANCELMODE, which
ends the tracking. Dropdowns flash and close on the item click (muffin),
need repeated clicks after opening (mutter, where the shuffle happens on
map), or glitch intermittently (KWin).

While the foreground thread reports GUI_INMENUMODE, only send the
WM_CANCELMODE when XGetInputFocus shows another client's window actually
holding the focus. None/PointerRoot means the WM's shuffle is still in
flight, and focus on a window of this process (the menu popup itself, or
another Live window) is no focus loss at all. A real switch to another
application still cancels the menu, and clicks outside the menu keep
closing it through the capture path, which never comes through here.

The NotifyGrab/NotifyUngrab modes were already filtered before
focus_out(); this covers the NotifyNormal FocusOut the WMs send once the
shuffle resolves.
---
 dlls/winex11.drv/event.c | 30 +++++++++++++++++++++++++++++-
 1 file changed, 29 insertions(+), 1 deletion(-)

diff --git a/dlls/winex11.drv/event.c b/dlls/winex11.drv/event.c
index 018e00e0..a5247610 100644
--- a/dlls/winex11.drv/event.c
+++ b/dlls/winex11.drv/event.c
@@ -682,6 +682,20 @@ BOOL is_current_process_focused(void)
     return FALSE;
 }
 
+/* whether the X input focus is provably held by another client's window;
+   None/PointerRoot mean the WM's focus shuffle is still in flight, not that
+   the focus left this process */
+static BOOL focus_held_by_other_client( Display *display )
+{
+    Window focus;
+    int revert;
+    HWND hwnd;
+
+    XGetInputFocus( display, &focus, &revert );
+    if (focus == None || focus == PointerRoot) return FALSE;
+    return XFindContext( display, focus, winContext, (char **)&hwnd ) != 0;
+}
+
 /**********************************************************************
  *              X11DRV_FocusIn
  */
@@ -747,7 +761,21 @@ static void focus_out( Display *display , HWND hwnd )
     if (is_virtual_desktop()) return;
     if (hwnd != NtUserGetForegroundWindow()) return;
     if (!(NtUserGetWindowLongW( hwnd, GWL_STYLE ) & WS_MINIMIZE))
-        send_message( hwnd, WM_CANCELMODE, 0, 0 );
+    {
+        GUITHREADINFO threadinfo;
+
+        /* Menu popups are override-redirect, and mapping or clicking one makes
+           mutter/muffin shuffle the X input focus; the resulting FocusOut lands
+           on the foreground window mid menu-track and the WM_CANCELMODE below
+           would kill the open dropdown.  While the foreground thread tracks a
+           menu, only cancel when another client provably took the focus. */
+        threadinfo.cbSize = sizeof(threadinfo);
+        if (NtUserGetGUIThreadInfo( 0, &threadinfo ) && (threadinfo.flags & GUI_INMENUMODE) &&
+            !focus_held_by_other_client( display ))
+            WARN( "Ignoring FocusOut on %p during menu tracking, focus did not leave the process\n", hwnd );
+        else
+            send_message( hwnd, WM_CANCELMODE, 0, 0 );
+    }
 
     /* don't reset the foreground window, if the window which is
        getting the focus is a Wine window */
