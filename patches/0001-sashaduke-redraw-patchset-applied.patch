+static BOOL dcomp_force_full_redraw(void)
+{
+    static int force_full = -1;
+
+    if (force_full == -1)
+    {
+        char value[8];
+        DWORD len;
+
+        force_full = 1;
+        len = GetEnvironmentVariableA("WINED3D_DCOMP_FORCE_FULL_REDRAW",
+                value, sizeof(value));
+        if (len && len < sizeof(value) && !strcmp(value, "0"))
+            force_full = 0;
+    }
+
+    return !!force_full;
+}
+
 /* Porter-Duff Over: C_out = C_src + C_dst * (1 - alpha_src)
  * Both src and dst are premultiplied alpha BGRA. */
