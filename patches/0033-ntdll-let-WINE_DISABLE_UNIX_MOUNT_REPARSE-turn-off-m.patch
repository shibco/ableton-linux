Subject: ntdll: let WINE_DISABLE_UNIX_MOUNT_REPARSE turn off
 mount-point reparse reporting

Wine reports Unix mount boundaries as IO_REPARSE_TAG_MOUNT_POINT reparse
points, but FSCTL_GET_REPARSE_POINT has no data for them. Applications
that canonicalize every reported reparse point (Live's browser walking
folders reached through the XDG portal dialogs and the Z: root mapping)
hit unresolvable junctions on every mount boundary. Setting
WINE_DISABLE_UNIX_MOUNT_REPARSE reports them as plain directories.

Origin: ENCORE (wowitsjack) patches/encore-wine.patch, dlls/ntdll/unix/file.c
hunks, reviewed and ported unchanged in behavior to this wine-11.11 tree.
---
 dlls/ntdll/unix/file.c | 20 +++++++++++++++++---
 1 file changed, 17 insertions(+), 3 deletions(-)

diff --git a/dlls/ntdll/unix/file.c b/dlls/ntdll/unix/file.c
index b641e4ca..dcf25dad 100644
--- a/dlls/ntdll/unix/file.c
+++ b/dlls/ntdll/unix/file.c
@@ -1662,6 +1662,16 @@ static int parse_samba_dos_attrib_data( char *data, int len )
 }
 
 
+static BOOL unix_mount_points_are_reparse_points(void)
+{
+    static int enabled = -1;
+
+    if (enabled == -1)
+        enabled = !getenv( "WINE_DISABLE_UNIX_MOUNT_REPARSE" );
+    return enabled;
+}
+
+
 static BOOL fd_is_mount_point( int fd, const struct stat *st )
 {
     struct stat parent;
@@ -1686,8 +1696,11 @@ static int fd_get_file_info( HANDLE handle, int fd, unsigned int options,
     if (ret == -1) return ret;
     *attr |= get_file_attributes( st );
     if (reparse_tag) *reparse_tag = 0;
-    /* consider mount points to be reparse points (IO_REPARSE_TAG_MOUNT_POINT) */
-    if (options & FILE_OPEN_REPARSE_POINT)
+    /* consider mount points to be reparse points (IO_REPARSE_TAG_MOUNT_POINT);
+     * some applications canonicalize every reported reparse point through
+     * FSCTL_GET_REPARSE_POINT, for which Unix mount boundaries have no data,
+     * so WINE_DISABLE_UNIX_MOUNT_REPARSE turns the reporting off */
+    if (unix_mount_points_are_reparse_points() && (options & FILE_OPEN_REPARSE_POINT))
     {
         if (fd_is_mount_point( fd, st ))
         {
@@ -1795,7 +1808,8 @@ static int get_file_info( const char *path, struct stat *st, ULONG *attr, ULONG
             if (reparse_tag) *reparse_tag = IO_REPARSE_TAG_LX_SYMLINK;
         }
     }
-    else if (S_ISDIR( st->st_mode ) && (parent_path = malloc( len + 4 )))
+    else if (unix_mount_points_are_reparse_points() && S_ISDIR( st->st_mode )
+            && (parent_path = malloc( len + 4 )))
     {
         struct stat parent_st;
 
