Subject: dxgi: don't blit stale-sized dcomp comp buffers into
 the target

Gate both comp-buffer blit sites on the buffer matching the swapchain's current desc (not the
client rect: comp dims are physical, an unaware target's client rect is logical).
---
 dlls/dxgi/factory.c | 40 +++++++++++++++++++++++++++++++++++++---
 1 file changed, 37 insertions(+), 3 deletions(-)

diff --git a/dlls/dxgi/factory.c b/dlls/dxgi/factory.c
index cf1ef6e7..c8357fd7 100644
--- a/dlls/dxgi/factory.c
+++ b/dlls/dxgi/factory.c
@@ -406,6 +406,28 @@ static inline struct d3d11_swapchain *d3d11_swapchain_from_IDXGISwapChain4(IDXGI
 /* DCOMP_REBLIT_TIMER_ID / DCOMP_POPUP_REBLIT_TIMER_ID moved to dxgi_private.h
  * so d3d11_swapchain_Release() can KillTimer them on teardown. */
 
+/* A comp buffer whose size predates the last ResizeBuffers is a stale
+ * snapshot in the old geometry; blitting it paints misframed content.
+ * WebView2's learn view creates its composition swapchain at the pane's
+ * transient initial size (e.g. 1273x1552) and resizes moments later
+ * (299x804) — the stale-size paints in between land as a mangled band
+ * that then fights Chromium's partial presents (visible flicker).
+ * Compare against the swapchain's current desc, not the client rect:
+ * comp dims are in swapchain (physical) units, while the client rect of
+ * a DPI-unaware target is logical — they legitimately differ under
+ * monitor scaling. */
+static BOOL dcomp_comp_buffer_current(HWND hwnd, unsigned int w, unsigned int h)
+{
+    IDXGISwapChain4 *sc = (IDXGISwapChain4 *)GetPropW(hwnd, L"__wine_dcomp_swapchain");
+    DXGI_SWAP_CHAIN_DESC1 desc;
+
+    if (!sc)
+        return TRUE;
+    if (FAILED(IDXGISwapChain4_GetDesc1(sc, &desc)))
+        return TRUE;
+    return desc.Width == w && desc.Height == h;
+}
+
 /* Re-blit composition content from persistent buffer to window.
  * Called on WM_PAINT, focus changes, timer tick, and other events
  * that may cause the window surface to be overwritten. */
@@ -424,8 +446,19 @@ static void dcomp_reblit_comp_buffer(HWND hwnd, const char *reason)
     {
         unsigned int w = LOWORD(dims);
         unsigned int h = HIWORD(dims);
-        HDC hdc = GetDC(hwnd);
-        if (hdc)
+        HDC hdc;
+
+        if (!dcomp_comp_buffer_current(hwnd, w, h))
+        {
+            static unsigned int stale_count;
+            ++stale_count;
+            if (stale_count <= 5 || !(stale_count % 200))
+                FIXME("Re-blit skipped (stale %ux%u buffer): hwnd %p reason=%s.\n",
+                        w, h, hwnd, reason);
+            return;
+        }
+
+        if ((hdc = GetDC(hwnd)))
         {
             static unsigned int reblit_count;
             ++reblit_count;
@@ -662,7 +695,8 @@ static LRESULT CALLBACK dcomp_target_wndproc(HWND hwnd, UINT msg, WPARAM wparam,
                             : DefWindowProcW(hwnd, msg, wparam, lparam);
 
             BeginPaint(hwnd, &ps);
-            if (comp_dc && dims)
+            if (comp_dc && dims
+                    && dcomp_comp_buffer_current(hwnd, LOWORD(dims), HIWORD(dims)))
             {
                 unsigned int w = LOWORD(dims);
                 unsigned int h = HIWORD(dims);
