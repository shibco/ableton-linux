+/* A seq port appeared (device plugged in, or a client like PipeWire's
+ * Midi-Bridge re-created a port).  If its display name matches a device we
+ * enumerated at init, adopt the new address and re-subscribe any open
+ * input/output — subscriptions die silently when the old port went away. */
+static void handle_port_start(snd_seq_addr_t addr)
+{
+    snd_seq_client_info_t *cinfo;
+    snd_seq_port_info_t *pinfo;
+    char name[MAXPNAMELEN];
+    WCHAR nameW[MAXPNAMELEN];
+    unsigned int cap, type, len;
+    struct midi_dest *dest;
+    struct midi_src *src;
+    int ret = 0;
+
+    cinfo = calloc( 1, snd_seq_client_info_sizeof() );
+    pinfo = calloc( 1, snd_seq_port_info_sizeof() );
+
+    seq_lock();
+    if (!midi_seq || addr.client == snd_seq_client_id(midi_seq) ||
+        snd_seq_get_any_client_info(midi_seq, addr.client, cinfo) < 0 ||
+        snd_seq_get_any_port_info(midi_seq, addr.client, addr.port, pinfo) < 0)
+        ret = -1;
+    seq_unlock();
+    if (ret < 0)
+        goto done;
+
+    cap = snd_seq_port_info_get_capability(pinfo);
+    type = snd_seq_port_info_get_type(pinfo);
+    if (!type || (cap & SND_SEQ_PORT_CAP_NO_EXPORT))
+        goto done;
+
+    len = port_display_name(cinfo, pinfo, name);
+    ntdll_umbstowcs(name, len + 1, nameW, ARRAY_SIZE(nameW));
+
+    if (cap & SND_SEQ_PORT_CAP_READ)
+    {
+        for (src = srcs; src < srcs + num_srcs; src++)
+        {
+            if (wcscmp(src->caps.szPname, nameW)) continue;
+            TRACE("re-attaching MidiIn %u '%s' to %d:%d\n",
+                  (unsigned int)(src - srcs), name, addr.client, addr.port);
+            src->addr = addr;
+            if (src->midiDesc.hMidi && src->seq)
+            {
+                seq_lock();
+                ret = snd_seq_connect_from(src->seq, src->port_in, addr.client, addr.port);
+                seq_unlock();
+                if (ret < 0)
+                    WARN("Could not re-subscribe MidiIn '%s' to %d:%d: %s\n",
+                         name, addr.client, addr.port, snd_strerror(ret));
+            }
+            break;
+        }
+    }
+    if (cap & SND_SEQ_PORT_CAP_WRITE)
+    {
+        for (dest = dests; dest < dests + num_dests; dest++)
+        {
+            if (wcscmp(dest->caps.szPname, nameW)) continue;
+            TRACE("re-attaching MidiOut %u '%s' to %d:%d\n",
+                  (unsigned int)(dest - dests), name, addr.client, addr.port);
+            dest->addr = addr;
+            if (dest->midiDesc.hMidi && dest->seq && dest->port_out >= 0)
+            {
+                seq_lock();
+                ret = snd_seq_connect_to(dest->seq, dest->port_out, addr.client, addr.port);
+                seq_unlock();
+                if (ret < 0)
+                    WARN("Could not re-subscribe MidiOut '%s' to %d:%d: %s\n",
+                         name, addr.client, addr.port, snd_strerror(ret));
+            }
+            break;
+        }
+    }
+
+done:
+    free( cinfo );
+    free( pinfo );
+}
+
 static void midi_handle_event(snd_seq_event_t *ev)
 {
     struct midi_src *src;
 
+    if (ev->source.client == SND_SEQ_CLIENT_SYSTEM && ev->source.port == SND_SEQ_PORT_SYSTEM_ANNOUNCE)
+    {
+        if (ev->type == SND_SEQ_EVENT_PORT_START)
+            handle_port_start(ev->data.addr);
+        return;
+    }
+
     /* Find the target device */
     for (src = srcs; src < srcs + num_srcs; src++)
         if ((ev->source.client == src->addr.client) && (ev->source.port == src->addr.port))
