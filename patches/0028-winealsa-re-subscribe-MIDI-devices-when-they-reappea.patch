                 TRACE("Unable to create input port\n");
             else
+            {
                 TRACE("Input port %d created successfully\n", port_in);
+                /* Subscribe to the system announce port so the record thread
+                 * sees ports (re)appear and can re-wire hotplugged devices. */
+                if (snd_seq_connect_from(midi_seq, port_in, SND_SEQ_CLIENT_SYSTEM, SND_SEQ_PORT_SYSTEM_ANNOUNCE) < 0)
+                    WARN("Could not subscribe to the system announce port\n");
