#!/usr/bin/env bash
# Ableton Live launcher for the patched Wine stack. Runs whichever Live edition
# (Intro/Lite/Standard/Suite/Trial, any major version) is installed in the prefix.
# Overrides: ABLETON_WINE_ROOT=/usr (stock wine), ABLETON_VDESK=2560x1600 (virtual desktop),
#            ABLETON_LIVE_EXE=/path/into/prefix/.../Ableton Live NN Edition.exe (pick one install).
set -u
# Clear inherited Wine variables so this launch uses only the patched build.
unset WINELOADER WINEDLLPATH WINEDLLOVERRIDES WINEARCH
WINE_ROOT="${ABLETON_WINE_ROOT:-$HOME/.local/opt/wine-d2d1-nspa-11.11}"
export WINEPREFIX="${ABLETON_WINEPREFIX:-$HOME/.wine-ableton}"
export PATH="$WINE_ROOT/bin:$PATH"
# Disable Wine debug logging; fixme spam from the D3D poll loop stalls Live's UI thread.
export WINEDEBUG="${WINEDEBUG:--all}"
export WINE_D3D_CONFIG="${WINE_D3D_CONFIG:-csmt=0x1}"
export WINED3D_DCOMP_FORCE_FULL_REDRAW="${WINED3D_DCOMP_FORCE_FULL_REDRAW:-1}"
# Report host mount points as plain dirs (patch 0033); Live's browser treats
# junctions without reparse data as unresolvable and skips them.
export WINE_DISABLE_UNIX_MOUNT_REPARSE="${WINE_DISABLE_UNIX_MOUNT_REPARSE:-1}"
export WINESERVER="$WINE_ROOT/bin/wineserver"

# Locate the installed Live: any 'Ableton Live*.exe' under ProgramData/Ableton.
# Several installs (editions or majors) may coexist; the newest wins unless pinned.
find_live_exe() {
    if [ -n "${ABLETON_LIVE_EXE:-}" ]; then
        printf '%s\n' "$ABLETON_LIVE_EXE"
        return
    fi
    ls "$WINEPREFIX"/drive_c/ProgramData/Ableton/*/Program/"Ableton Live"*.exe 2>/dev/null | sort -V
}
live_exe_unix="$(find_live_exe | tail -n 1)"
live_count="$(find_live_exe | grep -c .)"
EXE=""; exe_base=""
if [ -n "$live_exe_unix" ]; then
    exe_base="$(basename "$live_exe_unix")"
    if [ "$live_count" -gt 1 ]; then
        echo "ableton-live: $live_count Live installs in this prefix — launching '${exe_base%.exe}' (set ABLETON_LIVE_EXE to pick another)" >&2
    fi
    rel="${live_exe_unix#"$WINEPREFIX/drive_c/"}"
    if [ "$rel" != "$live_exe_unix" ]; then
        EXE="C:\\${rel//\//\\}"
    else
        EXE="$live_exe_unix"    # outside the prefix: wine resolves unix paths too
    fi
fi

# If Live isn't running, kill any stale wineserver so the prefix binds to this build's server.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep -q "ProgramData"; then
    "$WINE_ROOT/bin/wineserver" -k 2>/dev/null || true
    /usr/bin/wineserver -k 2>/dev/null || true
fi

# NVIDIA's EGL/X11 path has no default-depth RGBA8 window format under Wine;
# GLX does. Select it only for an active NVIDIA display (or explicit PRIME
# offload), and leave every other host's existing backend untouched.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep "ProgramData" >/dev/null; then
    opengl_mode="${ABLETON_OPENGL_BACKEND:-auto}"
    opengl_backend=preserve
    opengl_lib="$HOME/.local/share/ableton-wine/opengl-policy.sh"
    if [ -r "$opengl_lib" ]; then
        . "$opengl_lib"
        if ! opengl_backend="$(ableton_resolve_opengl_backend "$opengl_mode")"; then
            echo "ableton-live: ABLETON_OPENGL_BACKEND must be auto, preserve, egl, or glx" >&2
            opengl_backend=preserve
        fi
    elif [ "$opengl_mode" != auto ] && [ "$opengl_mode" != preserve ]; then
        echo "ableton-live: OpenGL backend policy library is missing — keeping the current backend" >&2
    fi
    cur_use_egl="$(awk '/^\[Software\\\\Wine\\\\X11 Driver\]/{f=1;next} /^\[/{f=0} f&&/"UseEGL"=/{gsub(/.*="/,""); gsub(/".*/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
    case "$opengl_backend" in
        glx)
            if [ "$cur_use_egl" != N ]; then
                if [ "$opengl_mode" = glx ]; then
                    echo "ableton-live: selecting Wine's GLX backend (explicit override)" >&2
                else
                    echo "ableton-live: active NVIDIA display — selecting Wine's GLX backend" >&2
                fi
                "$WINE_ROOT/bin/wine" reg add 'HKCU\Software\Wine\X11 Driver' /v UseEGL /t REG_SZ /d N /f >/dev/null 2>&1
            fi ;;
        egl)
            if [ "$cur_use_egl" != Y ]; then
                echo "ableton-live: selecting Wine's EGL backend (explicit override)" >&2
                "$WINE_ROOT/bin/wine" reg add 'HKCU\Software\Wine\X11 Driver' /v UseEGL /t REG_SZ /d Y /f >/dev/null 2>&1
            fi ;;
    esac
fi

# Recalibrate prefix DPI to the detected scale before each launch: 1.0 -> LogPixels 96 + no IFEO;
# 1.25 -> LogPixels 192 + IFEO=2; else preserve. ABLETON_DPI_MODE=100|fractional|preserve overrides.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep "ProgramData" >/dev/null; then
    dpi_mode="${ABLETON_DPI_MODE:-auto}"
    if [ "$dpi_mode" = auto ]; then
        dpi_lib="$HOME/.local/share/ableton-wine/detect-scale.sh"
        dpi_mode=preserve
        if [ -r "$dpi_lib" ]; then
            . "$dpi_lib"
            dpi_scale="$(ableton_detect_scale)" || dpi_scale=""
            case "$dpi_scale" in
                1)    dpi_mode=100 ;;
                1.25) dpi_mode=fractional ;;
                "")   ;;
                *)    echo "ableton-live: scale $dpi_scale detected, but only 100%/125% are calibrated — keeping current DPI values (set ABLETON_DPI_MODE to force)" >&2 ;;
            esac
        fi
    fi
    # The dpiAwareness IFEO is keyed on the exe name, so it follows the discovered install.
    dpi_ifeo=""; cur_ifeo=""
    if [ -n "$exe_base" ]; then
        dpi_ifeo="HKLM\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options\\$exe_base"
        cur_ifeo="$(awk '/^\[Software\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\Image File Execution Options\\\\'"$exe_base"'\]/{f=1;next} /^\[/{f=0} f&&/"dpiAwareness"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/system.reg" 2>/dev/null || true)"
    fi
    # Read current values from the registry files directly (no wineserver spin-up).
    cur_lp="$(awk '/^\[Control Panel\\\\Desktop\]/{f=1;next} /^\[/{f=0} f&&/"LogPixels"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
    case "$dpi_mode" in
        100)
            if [ "${cur_lp:-00000060}" != 00000060 ] || [ -n "$cur_ifeo" ]; then
                echo "ableton-live: display at 100% — recalibrating prefix DPI (LogPixels 96, no IFEO)" >&2
                "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop' /v LogPixels /t REG_DWORD /d 96 /f >/dev/null 2>&1
                [ -z "$dpi_ifeo" ] || "$WINE_ROOT/bin/wine" reg delete "$dpi_ifeo" /v dpiAwareness /f >/dev/null 2>&1 || true
            fi ;;
        fractional)
            if [ "${cur_lp:-}" != 000000c0 ] || { [ -n "$dpi_ifeo" ] && [ "${cur_ifeo:-}" != 00000002 ]; }; then
                echo "ableton-live: display at 125% — recalibrating prefix DPI (LogPixels 192, IFEO=2)" >&2
                "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop' /v LogPixels /t REG_DWORD /d 192 /f >/dev/null 2>&1
                [ -z "$dpi_ifeo" ] || "$WINE_ROOT/bin/wine" reg add "$dpi_ifeo" /v dpiAwareness /t REG_DWORD /d 2 /f >/dev/null 2>&1
            fi ;;
    esac
    # Warn if mutter's xwayland-native-scaling disagrees with the DPI set; never change it.
    if command -v gsettings >/dev/null 2>&1; then
        mutter_feats="$(gsettings get org.gnome.mutter experimental-features 2>/dev/null || true)"
        case "$dpi_mode" in
            100)        case "$mutter_feats" in *xwayland-native-scaling*)
                            echo "ableton-live: warn — mutter xwayland-native-scaling is ON; the 100% set expects it OFF" >&2 ;; esac ;;
            fractional) case "$mutter_feats" in *xwayland-native-scaling*) ;; *)
                            [ -n "$mutter_feats" ] && echo "ableton-live: warn — mutter xwayland-native-scaling is OFF; the 125% set expects it ON" >&2 ;; esac ;;
        esac
    fi
fi

# Mirror the host light/dark scheme into the prefix before each launch: Live's "Follow system"
# theme reads AppsUseLightTheme, which a scripted prefix never carries (the early snapshot-based
# installs inherited it). ABLETON_THEME_MODE=auto|dark|light|preserve overrides detection.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep "ProgramData" >/dev/null; then
    theme_mode="${ABLETON_THEME_MODE:-auto}"
    if [ "$theme_mode" = auto ]; then
        theme_lib="$HOME/.local/share/ableton-wine/detect-theme.sh"
        theme_mode=preserve
        if [ -r "$theme_lib" ]; then
            . "$theme_lib"
            host_scheme="$(ableton_detect_theme)" || host_scheme=""
            case "$host_scheme" in dark|light) theme_mode="$host_scheme" ;; esac
        fi
    fi
    case "$theme_mode" in dark) want_light=0 ;; light) want_light=1 ;; *) want_light="" ;; esac
    if [ -n "$want_light" ]; then
        # Current value straight from the registry file (no wineserver spin-up when unchanged).
        cur_light="$(awk '/^\[Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Themes\\\\Personalize\]/{f=1;next} /^\[/{f=0} f&&/"AppsUseLightTheme"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
        if [ "${cur_light:-absent}" != "0000000$want_light" ]; then
            echo "ableton-live: host scheme is $theme_mode — setting the prefix theme to match" >&2
            "$WINE_ROOT/bin/wine" reg add 'HKCU\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize' /v AppsUseLightTheme /t REG_DWORD /d "$want_light" /f >/dev/null 2>&1
        fi
    fi
fi

# Audio: PipeASIO -> PipeWire (native client, no JACK layer). Defaults live in
# ~/.config/pipeasio/config.ini (seeded by setup-prefix.sh); PIPEASIO_* variables
# override per launch — raise PIPEASIO_PREFERRED_BUFFERSIZE to 512 if crackles.

require_live() {
    [ -n "$EXE" ] && return 0
    echo "ableton-live: no Ableton Live installation found in $WINEPREFIX" >&2
    echo "ableton-live: rerun the ableton-wine-setup .run with your Ableton download (any edition) next to it, or install Live manually — see the README" >&2
    exit 1
}

run=(wine)
if command -v chrt >/dev/null 2>&1 && chrt -r 10 true >/dev/null 2>&1; then
    run=(chrt -r 10 wine)
fi

if [ -n "${ABLETON_VDESK:-}" ]; then
    require_live
    exec "${run[@]}" explorer "/desktop=AbletonLive,${ABLETON_VDESK}" "$EXE"
elif [ "$#" -gt 0 ]; then
    # ableton:// URLs, .auz license files, .als sets from the file manager
    exec "${run[@]}" start "$@"
else
    require_live
    exec "${run[@]}" "$EXE"
fi
