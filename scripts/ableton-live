#!/usr/bin/env bash
# Ableton Live launcher for the patched Wine stack. Runs whichever Live edition
# (Intro/Lite/Standard/Suite/Trial, any major version) is installed in the prefix.
# Overrides: ABLETON_WINE_ROOT=/usr (stock wine), ABLETON_VDESK=2560x1600 (virtual desktop),
#            ABLETON_LIVE_EXE=/path/into/prefix/.../Ableton Live NN Edition.exe (pick one install),
#            ABLETON_LIVE_VERSION=11|12 (restrict discovery to one major version),
#            ABLETON_RT=off (skip the realtime probe; run Live under normal scheduling).
set -u
# Clear inherited Wine variables so this launch uses only the patched build.
unset WINELOADER WINEDLLPATH WINEDLLOVERRIDES WINEARCH
WINE_ROOT="${ABLETON_WINE_ROOT:-$HOME/.local/opt/wine-d2d1-nspa-11.11}"
export WINEPREFIX="${ABLETON_WINEPREFIX:-$HOME/.wine-ableton}"
export PATH="$WINE_ROOT/bin:$PATH"
# Disable Wine debug logging; fixme spam from the D3D poll loop stalls Live's UI thread.
export WINEDEBUG="${WINEDEBUG:--all}"
export WINE_D3D_CONFIG="${WINE_D3D_CONFIG:-csmt=0x1}"
export WINED3D_DCOMP_FORCE_FULL_REDRAW="${WINED3D_DCOMP_FORCE_FULL_REDRAW:-1}"
# Report host mount points as plain dirs (patch 0033); Live's browser treats
# junctions without reparse data as unresolvable and skips them.
export WINE_DISABLE_UNIX_MOUNT_REPARSE="${WINE_DISABLE_UNIX_MOUNT_REPARSE:-1}"
export WINESERVER="$WINE_ROOT/bin/wineserver"

# Keep Wine's Mono/.NET and HTML-help hooks out of Live — nothing in the
# stack loads them. winemenubuilder.exe is deliberately absent here: setup-prefix.sh
# already disables it registry-side, and that form stays canonical.
export WINEDLLOVERRIDES="${WINEDLLOVERRIDES:+$WINEDLLOVERRIDES;}mscoree,mshtml="
# Opt-in A/B against the open Learn View flicker (notes/ABLETON-WINE-LEARNVIEW-FLICKER.md):
# ABLETON_DCOMP=off disables DirectComposition outright. Off contradicts the d2d1-dcomp
# stack this runtime ships (WINED3D_DCOMP_FORCE_FULL_REDRAW above), so it is no default.
if [ "${ABLETON_DCOMP:-on}" = "off" ]; then
    export WINEDLLOVERRIDES="$WINEDLLOVERRIDES;dcomp="
fi
# Live 12's Learn View is a WebView2 (Chromium) embed; force the SwiftShader software
# path, which renders where GPU compositing under Wine does not. --no-sandbox is
# mandatory: nothing under Wine can sandbox the renderer. User-supplied flags come first.
export WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS="${WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS:+$WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS }--use-gl=angle --use-angle=swiftshader --disable-gpu-compositing --disable-gpu-rasterization --disable-direct-composition --disable-features=ForceSWDCompWhenDCompFallbackRequired --edge-webview-foreground-boost-opt-out --no-sandbox"

# Report a stable, small CPU count to Live — cap 8, honoring taskset/cgroup cpusets. 
# Emit 8 when usable CPUs exceed 8, the allowed-set size when affinity-constrained 
# below that, and nothing otherwise (Wine's default is fine).
# A user-set WINE_CPU_TOPOLOGY always wins. Inert on this runtime until the patched
# ntdll/wineserver consumer lands; exported as groundwork only.
select_cpu_topology() {
    local online allowed list part lo hi
    online="$(getconf _NPROCESSORS_ONLN 2>/dev/null)" || online=""
    case "$online" in ""|*[!0-9]*) return 1 ;; esac
    allowed="$online"
    list="$(awk '/^Cpus_allowed_list:/{print $2; exit}' /proc/self/status 2>/dev/null)"
    if [ -n "$list" ]; then
        allowed=0
        for part in ${list//,/ }; do
            case "$part" in
                *-*) lo="${part%%-*}"; hi="${part##*-}"
                     case "$lo$hi" in ""|*[!0-9]*) return 1 ;; esac
                     allowed=$((allowed + hi - lo + 1)) ;;
                *)   case "$part" in *[!0-9]*) return 1 ;; esac
                     allowed=$((allowed + 1)) ;;
            esac
        done
    fi
    [ "$allowed" -ge 1 ] || return 1
    if [ "$allowed" -gt 8 ]; then
        printf '8\n'
    elif [ "$allowed" -lt "$online" ]; then
        printf '%d\n' "$allowed"
    fi
}
if [ -z "${WINE_CPU_TOPOLOGY:-}" ]; then
    cpu_topology="$(select_cpu_topology)" || cpu_topology=""
    [ -n "$cpu_topology" ] && export WINE_CPU_TOPOLOGY="$cpu_topology"
fi

# Single-instance guard with no Live process up, exactly one
# launcher may bring it up — a concurrent second launch would race the wineserver kill
# and the DPI/theme re-sync below. Once Live runs there is nothing to serialize (the
# pgrep checks skip the re-sync; wine forwards to the running instance), so the guard
# stays off that path. fd 9 must never leak into a wine child: a spawned wineserver
# would pin the lock for the whole session (start_server posix_spawns with inherited
# fds), so the lock is dropped again just before the exec at the bottom, and every
# wine registry call made during bring-up closes it explicitly (9>&-) — without that,
# a failed launch leaves the sync-spawned wineserver holding the lock, and relaunching
# is refused until that server exits.
launch_lock="$WINEPREFIX/.ableton-live.lock"
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep -q "ProgramData"; then
    if [ -d "$WINEPREFIX" ] && [ -w "$WINEPREFIX" ] && command -v flock >/dev/null 2>&1; then
        exec 9>"$launch_lock"
        if ! flock -n 9; then
            echo "ableton-live: another launcher is bringing Live up (lock: $launch_lock) — refusing a second instance" >&2
            exit 1
        fi
        printf '%s\n' "$$" >&9   # lock owner PID, for debugging
    fi
fi

# Locate the installed Live: any 'Ableton Live*.exe' under ProgramData/Ableton.
# Several installs (editions or majors) may coexist. ABLETON_LIVE_EXE pins one exact
# install; ABLETON_LIVE_VERSION (e.g. 11) restricts discovery to one major. Without a
# pin the newest wins, unless every install shares one major — ambiguity inside a
# single major is a hard failure (refuse to guess) that prints the discovery list.
case "${ABLETON_LIVE_VERSION:-}" in
    "") ;;
    *[!0-9]*)
        echo "ableton-live: ABLETON_LIVE_VERSION must be a major version number (e.g. 11 or 12), got '$ABLETON_LIVE_VERSION'" >&2
        exit 2 ;;
esac
find_live_exe() {  # $1 = optional major-version filter
    if [ -n "${ABLETON_LIVE_EXE:-}" ]; then
        printf '%s\n' "$ABLETON_LIVE_EXE"
        return
    fi
    if [ -n "${1:-}" ]; then
        ls "$WINEPREFIX"/drive_c/ProgramData/Ableton/*/Program/"Ableton Live $1 "*.exe 2>/dev/null | sort -V
    else
        ls "$WINEPREFIX"/drive_c/ProgramData/Ableton/*/Program/"Ableton Live"*.exe 2>/dev/null | sort -V
    fi
}
live_exe_unix="$(find_live_exe "${ABLETON_LIVE_VERSION:-}" | tail -n 1)"
live_count="$(find_live_exe "${ABLETON_LIVE_VERSION:-}" | grep -c .)"
if [ -z "$live_exe_unix" ] && [ -n "${ABLETON_LIVE_VERSION:-}" ]; then
    echo "ableton-live: no Live $ABLETON_LIVE_VERSION install found in $WINEPREFIX" >&2
    if find_live_exe | grep -q .; then
        echo "ableton-live: the prefix holds other majors (unset ABLETON_LIVE_VERSION to use them):" >&2
        find_live_exe | sed 's/^/ableton-live:   /' >&2
    fi
    exit 1
fi
EXE=""; exe_base=""
if [ -n "$live_exe_unix" ]; then
    exe_base="$(basename "$live_exe_unix")"
    if [ "$live_count" -gt 1 ] && [ -z "${ABLETON_LIVE_EXE:-}" ]; then
        live_majors="$(find_live_exe "${ABLETON_LIVE_VERSION:-}" \
            | while IFS= read -r f; do basename "$f"; done | awk '{print $3}' | sort -u | paste -sd' ' -)"
        if [ "$(printf '%s' "$live_majors" | wc -w)" -eq 1 ]; then
            # One major, several installs, no exact pin: never guess which edition.
            echo "ableton-live: $live_count Live $live_majors installs in this prefix — refusing to guess:" >&2
            find_live_exe "${ABLETON_LIVE_VERSION:-}" | sed 's/^/ableton-live:   /' >&2
            echo "ableton-live: set ABLETON_LIVE_EXE=/path/into/prefix/.../'Ableton Live NN Edition.exe' to pick one" >&2
            exit 1
        fi
        echo "ableton-live: $live_count Live installs in this prefix (majors: $live_majors) — launching '${exe_base%.exe}' (set ABLETON_LIVE_VERSION to pin a major, or ABLETON_LIVE_EXE to pick an exact install)" >&2
    fi
    rel="${live_exe_unix#"$WINEPREFIX/drive_c/"}"
    if [ "$rel" != "$live_exe_unix" ]; then
        EXE="C:\\${rel//\//\\}"
    else
        EXE="$live_exe_unix"    # outside the prefix: wine resolves unix paths too
    fi
fi

# If Live isn't running, kill any stale wineserver so the prefix binds to this build's server.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep -q "ProgramData"; then
    "$WINE_ROOT/bin/wineserver" -k 2>/dev/null || true
    /usr/bin/wineserver -k 2>/dev/null || true
    # Boot the session synchronously before the registry sync below. Console clients
    # (reg.exe) skip the wineboot-event wait GUI apps honor, and a write racing the
    # async session boot can be dropped (observed: the FontSubstitutes sync lost its
    # HKLM write on a fresh session). wineboot exits when the boot pass is done; Live
    # would spin this server up moments later anyway.
    "$WINE_ROOT/bin/wine" wineboot >/dev/null 2>&1 9>&- || true
fi

# Recalibrate prefix DPI to the detected scale before each launch. The block comes from
# detect-scale.sh: GNOME (upscaled framebuffer) -> LogPixels = 96 x ceil(scale) + IFEO=2;
# other compositors -> LogPixels = round(96 x scale), no IFEO. Scales outside 100-250%
# keep current values. ABLETON_DPI_MODE=100|fractional|dpi<N>|preserve overrides.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep "ProgramData" >/dev/null; then
    dpi_mode="${ABLETON_DPI_MODE:-auto}"
    dpi_family=""; dpi_scale=""
    dpi_lib="$HOME/.local/share/ableton-wine/detect-scale.sh"
    # Packaged installs (nix) ship the libs under the runtime root instead of $HOME.
    [ -r "$dpi_lib" ] || dpi_lib="$WINE_ROOT/share/ableton-wine/scripts/detect-scale.sh"
    [ -r "$dpi_lib" ] && . "$dpi_lib"
    if ! declare -F ableton_dpi_block_values >/dev/null 2>&1; then
        # no (or an older) detect-scale.sh: the two legacy blocks still resolve inline
        ableton_dpi_block_values() {
            case "$1" in
                100)        printf '96 -\n' ;;
                fractional) printf '192 2\n' ;;
                *) return 1 ;;
            esac
        }
    fi
    if [ "$dpi_mode" = auto ]; then
        dpi_mode=preserve
        if declare -F ableton_detect_scale_ex >/dev/null 2>&1; then
            detected="$(ableton_detect_scale_ex)" || detected=""
            if [ -n "$detected" ]; then
                dpi_scale="${detected% *}"
                dpi_family="${detected#* }"
                if ! dpi_mode="$(ableton_dpi_block_for_scale "$dpi_scale" "$dpi_family")"; then
                    dpi_mode=preserve
                    echo "ableton-live: scale $dpi_scale is outside the calibrated 100-250% range — keeping current DPI values (set ABLETON_DPI_MODE to force)" >&2
                fi
            fi
        elif declare -F ableton_detect_scale >/dev/null 2>&1; then
            # older detect-scale.sh without the family/mapping helpers: the two legacy blocks
            dpi_scale="$(ableton_detect_scale)" || dpi_scale=""
            case "$dpi_scale" in
                1)    dpi_mode=100 ;;
                1.25) dpi_mode=fractional ;;
                "")   ;;
                *)    echo "ableton-live: scale $dpi_scale detected, but only 100%/125% are calibrated — keeping current DPI values (set ABLETON_DPI_MODE to force)" >&2 ;;
            esac
        fi
    fi
    # The dpiAwareness IFEO is keyed on the exe name, so it follows the discovered install.
    dpi_ifeo=""; cur_ifeo=""
    if [ -n "$exe_base" ]; then
        dpi_ifeo="HKLM\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Image File Execution Options\\$exe_base"
        cur_ifeo="$(awk '/^\[Software\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\Image File Execution Options\\\\'"$exe_base"'\]/{f=1;next} /^\[/{f=0} f&&/"dpiAwareness"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/system.reg" 2>/dev/null || true)"
    fi
    # Read current values from the registry files directly (no wineserver spin-up).
    cur_lp="$(awk '/^\[Control Panel\\\\Desktop\]/{f=1;next} /^\[/{f=0} f&&/"LogPixels"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
    case "$dpi_mode" in
        preserve) ;;
        *)
            lp_ifeo="$(ableton_dpi_block_values "$dpi_mode" 2>/dev/null)" || lp_ifeo=""
            if [ -z "$lp_ifeo" ]; then
                echo "ableton-live: unknown ABLETON_DPI_MODE '$dpi_mode' — keeping current DPI values" >&2
            else
                want_lp="${lp_ifeo% *}"
                want_ifeo="${lp_ifeo#* }"
                want_lp_hex="$(printf '%08x' "$want_lp")"
                if [ "$want_ifeo" = 2 ]; then
                    if [ "${cur_lp:-}" != "$want_lp_hex" ] || { [ -n "$dpi_ifeo" ] && [ "${cur_ifeo:-}" != 00000002 ]; }; then
                        echo "ableton-live: recalibrating prefix DPI to the '$dpi_mode' set (LogPixels $want_lp, IFEO=2)" >&2
                        "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop' /v LogPixels /t REG_DWORD /d "$want_lp" /f >/dev/null 2>&1 9>&-
                        [ -z "$dpi_ifeo" ] || "$WINE_ROOT/bin/wine" reg add "$dpi_ifeo" /v dpiAwareness /t REG_DWORD /d 2 /f >/dev/null 2>&1 9>&-
                    fi
                else
                    if [ "${cur_lp:-00000060}" != "$want_lp_hex" ] || [ -n "$cur_ifeo" ]; then
                        echo "ableton-live: recalibrating prefix DPI to the '$dpi_mode' set (LogPixels $want_lp, no IFEO)" >&2
                        "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop' /v LogPixels /t REG_DWORD /d "$want_lp" /f >/dev/null 2>&1 9>&-
                        [ -z "$dpi_ifeo" ] || "$WINE_ROOT/bin/wine" reg delete "$dpi_ifeo" /v dpiAwareness /f >/dev/null 2>&1 9>&- || true
                    fi
                fi
            fi ;;
    esac
    # Warn if mutter's xwayland-native-scaling disagrees with the DPI set; never change it.
    # The knob only exists under mutter — skip when another compositor family was detected.
    if [ -z "$dpi_family" ] || [ "$dpi_family" = gnome ]; then
        if command -v gsettings >/dev/null 2>&1; then
            mutter_feats="$(gsettings get org.gnome.mutter experimental-features 2>/dev/null || true)"
            case "$dpi_mode" in
                fractional*)   # upscaled-framebuffer sets expect the knob ON
                    case "$mutter_feats" in *xwayland-native-scaling*) ;; *)
                        [ -n "$mutter_feats" ] && echo "ableton-live: warn — mutter xwayland-native-scaling is OFF; the '$dpi_mode' set expects it ON" >&2 ;; esac ;;
                100|dpi*)
                    case "$mutter_feats" in *xwayland-native-scaling*)
                        echo "ableton-live: warn — mutter xwayland-native-scaling is ON; the '$dpi_mode' set expects it OFF" >&2 ;; esac ;;
            esac
        fi
    fi
fi

# win32u-drawn menus — Live's menu bar and dropdowns — take their colors from the
# [Control Panel\Colors] table, which neither the prefix setup nor the theme sync below
# has ever written, so the bar keeps stock light colors in dark mode. Sync the entries
# the bar uses alongside AppsUseLightTheme (current values read from the registry file,
# no wineserver spin-up when unchanged). When the host titlebar colors are known
# (issue #32), the bar and its text take those instead, so the WM titlebar and Live's
# menu bar read as one unified strip; the wine-drawn title colors (virtual desktops)
# follow along. Do NOT add "Window" here: a dark Window color blacks out comdlg32
# dialog lists.
sync_win32_colors() {   # dark|light [bar-bg bar-fg [menu-bg sel-bg sel-fg]]  ("R G B")
    local scheme="$1" bar_bg="${2:-}" bar_fg="${3:-}" menu_bg="${4:-}" sel_bg="${5:-}" sel_fg="${6:-}"
    local pair name want cur changed=0 menubar menutext menu
    local -a pairs
    case "$scheme" in
        dark)   menubar="43 43 43";    menutext="232 232 232"; menu="43 43 43"
                pairs=("ButtonFace=64 64 64" "ButtonText=232 232 232") ;;
        light)  menubar="240 240 240"; menutext="0 0 0";       menu="255 255 255"
                pairs=("ButtonFace=240 240 240" "ButtonText=0 0 0") ;;
        *)      return 0 ;;
    esac
    if [ -n "$bar_bg" ] && [ -n "$bar_fg" ]; then
        menubar="$bar_bg"; menutext="$bar_fg"
        pairs+=("ActiveTitle=$bar_bg" "GradientActiveTitle=$bar_bg" "TitleText=$bar_fg")
    fi
    [ -n "$menu_bg" ] && menu="$menu_bg"
    # Selected-item colors only ever move as a set: the menu highlight fill
    # (MenuHilight), the general selection fill (Hilight) and the selection text
    # (HilightText) — win32u draws selected menu text with HilightText, so a themed
    # fill under the stock white text would be unreadable.
    if [ -n "$sel_bg" ] && [ -n "$sel_fg" ]; then
        pairs+=("MenuHilight=$sel_bg" "Hilight=$sel_bg" "HilightText=$sel_fg")
    fi
    pairs+=("Menu=$menu" "MenuBar=$menubar" "MenuText=$menutext")
    for pair in "${pairs[@]}"; do
        name="${pair%%=*}"
        want="${pair#*=}"
        cur="$(awk -v n="\"$name\"=" '
            /^\[Control Panel\\\\Colors\]/ { f=1; next }
            /^\[/ { f=0 }
            f && index($0, n) == 1 {
                v = substr($0, length(n) + 1)
                sub(/^"/, "", v); sub(/"\r?$/, "", v)
                print v; exit
            }' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
        if [ "$cur" != "$want" ]; then
            [ "$changed" -eq 0 ] && echo "ableton-live: syncing the win32 menu colors to the $scheme scheme" >&2
            changed=1
            "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Colors' /v "$name" /t REG_SZ /d "$want" /f >/dev/null 2>&1 9>&-
        fi
    done
}

# The bar only paints with the MenuBar color when the flat-menu preference is on
# (win32u picks COLOR_MENUBAR over COLOR_MENU off SPI_GETFLATMENU); flat is also how
# Windows 10/11 draw menus. The preference is bit 0x02 of byte 2 in the
# UserPreferencesMask blob — set that one bit, keep every other preference.
ensure_flat_menu() {
    local cur b2 hex
    local -a bytes
    cur="$(awk '/^\[Control Panel\\\\Desktop\]/{f=1;next} /^\[/{f=0} f&&/"UserPreferencesMask"=hex:/{gsub(/.*hex:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
    [ -n "$cur" ] || cur="10,00,00,80,12,00,00,00"    # win32u's built-in default
    IFS=, read -ra bytes <<< "$cur"
    [ "${#bytes[@]}" -ge 8 ] || return 0
    b2=$(( 16#${bytes[2]} )) 2>/dev/null || return 0
    [ $(( b2 & 0x02 )) -ne 0 ] && return 0
    printf -v 'bytes[2]' '%02x' $(( b2 | 0x02 ))
    hex="$(IFS=''; printf '%s' "${bytes[*]}")"
    echo "ableton-live: enabling flat menus so the bar can take the titlebar color" >&2
    "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop' /v UserPreferencesMask /t REG_BINARY /d "$hex" /f >/dev/null 2>&1 9>&-
}

# "#RRGGBB #RRGGBB" (ABLETON_TOPBAR_MODE override) -> "R G B|R G B" (bg|text)
parse_topbar_override() {
    local bg fg rest c
    read -r bg fg rest <<< "$1"
    [ -z "$rest" ] || return 1
    for c in "$bg" "$fg"; do
        case "$c" in
            \#[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]) ;;
            *) return 1 ;;
        esac
    done
    printf '%d %d %d|%d %d %d\n' \
        $(( 16#${bg:1:2} )) $(( 16#${bg:3:2} )) $(( 16#${bg:5:2} )) \
        $(( 16#${fg:1:2} )) $(( 16#${fg:3:2} )) $(( 16#${fg:5:2} ))
}

# ABLETON_TOPBAR_MODE=live: color the chrome with Live's active theme, so the bar
# and menus continue Live's own surface (the Push 3 standalone look). Ground and
# text come from the theme's Desktop and ControlForeground; the selection set from
# SelectionBackground/SelectionForeground (see detect-theme.sh for the resolution).
resolve_live_topbar() {   # sets topbar/menu_bg/sel_bg/sel_fg; fails when unresolvable
    local themes major theme_file bg fg
    [ -n "$live_exe_unix" ] || return 1
    declare -F ableton_live_theme_file >/dev/null 2>&1 || return 1
    themes="${live_exe_unix%/Program/*}/Resources/Themes"
    major="$(printf '%s\n' "$exe_base" | awk '{print $3}')"
    theme_file="$(ableton_live_theme_file "$WINEPREFIX" "$themes" "$major" "$theme_mode")" || return 1
    # The bar sits on Live's transport strip, which renders ControlBackground —
    # Desktop (the surface behind the views) reads as a visible seam there.
    # Dropdowns take Desktop, matching Live's own popup surfaces.
    bg="$(ableton_ask_color "$theme_file" ControlBackground)" || return 1
    fg="$(ableton_ask_color "$theme_file" ControlForeground)" || return 1
    topbar="$bg|$fg"
    menu_bg="$(ableton_ask_color "$theme_file" Desktop)" || menu_bg="$bg"
    sel_bg="$(ableton_ask_color "$theme_file" SelectionBackground)" || sel_bg=""
    sel_fg="$(ableton_ask_color "$theme_file" SelectionForeground)" || sel_fg=""
    return 0
}

detect_system_topbar() {   # sets topbar from the host titlebar colors
    declare -F ableton_detect_topbar_colors >/dev/null 2>&1 || return 0
    topbar="$(ableton_detect_topbar_colors "$theme_mode")" || topbar=""
}

# With ABLETON_TOPBAR_MODE=live the bar keeps following while Live runs: Live
# flushes Preferences.cfg when its settings dialog closes (and on exit), so a
# theme picked there lands on disk moments later. Watch the newest cfg and
# re-apply through setsyscolors.exe — SetSysColors updates the running session
# (volatile color entries plus a WM_SYSCOLORCHANGE broadcast and redraw), so the
# bar and menus repaint without a restart; the per-launch sync persists the
# colors for the next session. One watcher per prefix (own lock, fd 8); exits
# when Live does.
theme_watch_prefs_cfg() {
    local major
    major="$(printf '%s\n' "$exe_base" | awk '{print $3}')"
    ls "$WINEPREFIX"/drive_c/users/*/AppData/Roaming/Ableton/"Live ${major:-}"*/Preferences/Preferences.cfg 2>/dev/null | sort -V | tail -n 1
}
theme_watch_loop() {
    local apply="$HOME/.local/share/ableton-wine/setsyscolors.exe"
    [ -f "$apply" ] || apply="$WINE_ROOT/share/ableton-wine/scripts/setsyscolors.exe"
    local lock="$WINEPREFIX/.ableton-theme-watch.lock" cfg last="" cur bar_bg bar_fg
    [ -f "$apply" ] || return 0
    command -v flock >/dev/null 2>&1 || return 0
    exec 8>"$lock" || return 0
    # the previous session's watcher exits within seconds of Live going down;
    # wait it out rather than losing the handover race
    for _ in 1 2 3 4 5 6 7 8; do
        flock -n 8 && break
        sleep 2
    done
    flock -n 8 || return 0
    for _ in {1..30}; do
        pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep -q ProgramData && break
        sleep 2
    done
    cfg="$(theme_watch_prefs_cfg)"
    [ -n "$cfg" ] && last="$(stat -c %Y "$cfg" 2>/dev/null)"
    while pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep -q ProgramData; do
        sleep 2
        cfg="$(theme_watch_prefs_cfg)"
        [ -n "$cfg" ] || continue
        cur="$(stat -c %Y "$cfg" 2>/dev/null)" || continue
        [ "$cur" = "$last" ] && continue
        last="$cur"
        topbar=""; menu_bg=""; sel_bg=""; sel_fg=""
        resolve_live_topbar || continue
        bar_bg="${topbar%%|*}"; bar_bg="${bar_bg// /,}"
        bar_fg="${topbar##*|}"; bar_fg="${bar_fg// /,}"
        set -- "MenuBar=$bar_bg" "MenuText=$bar_fg" "ActiveTitle=$bar_bg" \
               "GradientActiveTitle=$bar_bg" "TitleText=$bar_fg"
        [ -n "$menu_bg" ] && set -- "$@" "Menu=${menu_bg// /,}"
        if [ -n "$sel_bg" ] && [ -n "$sel_fg" ]; then
            set -- "$@" "MenuHilight=${sel_bg// /,}" "Hilight=${sel_bg// /,}" "HilightText=${sel_fg// /,}"
        fi
        "$WINE_ROOT/bin/wine" "$apply" "$@" >/dev/null 2>&1
    done
}

# Chrome typeface (issue #32): Live ships its own UI faces (Ableton Sans, plus the
# small-size cut Ableton Sans Small) in the install's Resources/Fonts, but the win32
# chrome around it — menu bar, context menus, message boxes — still renders Tahoma.
# Symlink the faces into the prefix's Fonts dir (win32u rescans it on every process
# start) and point both the shell-dialog substitutes and the WindowMetrics non-client
# fonts at them. The WindowMetrics LOGFONTs are patched in place: only the 64
# face-name bytes at offset 28 change, so the DPI-scaled heights and per-entry weights
# survive. ABLETON_UI_FONT=preserve touches nothing, =off restores wine's stock
# Tahoma, any other value is used verbatim as the family name.

reg_windowmetrics_hex() {   # value name -> "aa,bb,..." with continuation lines joined
    awk -v n="\"$1\"=hex:" '
        /^\[Control Panel\\\\Desktop\\\\WindowMetrics\]/ { f=1; next }
        /^\[/ { f=0 }
        f && index($0, n) == 1 {
            v = substr($0, length(n) + 1)
            while (v ~ /\\$/) {
                sub(/\\$/, "", v)
                if ((getline nl) <= 0) break
                gsub(/^[ \t]+/, "", nl)
                v = v nl
            }
            gsub(/\r/, "", v)
            print v; exit
        }' "$WINEPREFIX/user.reg" 2>/dev/null
}

logfont_face_hex() {   # family -> UTF-16LE face-name bytes, zero-padded to LF_FACESIZE
    local s="$1" out="" i ch
    [ "${#s}" -le 31 ] || return 1
    case "$s" in *[![:ascii:]]*) return 1 ;; esac   # blob is built bytewise from ASCII
    for (( i = 0; i < 32; i++ )); do
        if [ "$i" -lt "${#s}" ]; then
            printf -v ch '%02x' "'${s:$i:1}"
            out+="$ch,00,"
        else
            out+="00,00,"
        fi
    done
    printf '%s\n' "${out%,}"
}

sync_metric_fonts() {   # family -> repoint the non-client LOGFONTs, heights preserved
    local fam="$1" face_hex name cur head cur_face changed=0
    face_hex="$(logfont_face_hex "$fam")" || return 0
    for name in MenuFont MessageFont StatusFont CaptionFont SmCaptionFont; do
        cur="$(reg_windowmetrics_hex "$name")"
        # absent: win32u falls back to "MS Shell Dlg", which the substitutes cover
        [ -n "$cur" ] || continue
        head="$(printf '%s' "$cur" | cut -d, -f1-28)"
        [ "$(printf '%s' "$head" | awk -F, '{print NF}')" -eq 28 ] || continue
        cur_face="$(printf '%s' "$cur" | cut -d, -f29-92)"
        [ "$cur_face" = "$face_hex" ] && continue
        [ "$changed" -eq 0 ] && echo "ableton-live: pointing the win32 chrome fonts at '$fam'" >&2
        changed=1
        "$WINE_ROOT/bin/wine" reg add 'HKCU\Control Panel\Desktop\WindowMetrics' /v "$name" \
            /t REG_BINARY /d "$(printf '%s,%s' "$head" "$face_hex" | tr -d ,)" /f >/dev/null 2>&1 9>&-
    done
}

sync_font_substitutes() {   # family -> route the shell-dialog faces to it
    local fam="$1" name cur changed=0
    for name in "MS Shell Dlg" "MS Shell Dlg 2"; do
        cur="$(awk -v n="\"$name\"=" '
            /^\[Software\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\FontSubstitutes\]/ { f=1; next }
            /^\[/ { f=0 }
            f && index($0, n) == 1 {
                v = substr($0, length(n) + 1)
                sub(/^"/, "", v); sub(/"\r?$/, "", v)
                print v; exit
            }' "$WINEPREFIX/system.reg" 2>/dev/null || true)"
        if [ "$cur" != "$fam" ]; then
            [ "$changed" -eq 0 ] && echo "ableton-live: substituting the shell dialog faces with '$fam'" >&2
            changed=1
            "$WINE_ROOT/bin/wine" reg add 'HKLM\Software\Microsoft\Windows NT\CurrentVersion\FontSubstitutes' \
                /v "$name" /t REG_SZ /d "$fam" /f >/dev/null 2>&1 9>&-
        fi
    done
}

sync_ui_font() {
    local mode="${ABLETON_UI_FONT:-auto}" winfonts="$WINEPREFIX/drive_c/windows/Fonts"
    local fonts_dir="" family="" f linked=0
    [ "$mode" = preserve ] && return 0
    [ -d "$winfonts" ] || return 0
    # Links from an install that was since removed or upgraded must not linger.
    for f in "$winfonts"/AbletonSans*; do
        [ -L "$f" ] && [ ! -e "$f" ] && rm -f "$f"
    done
    if [ "$mode" = off ]; then
        for f in "$winfonts"/AbletonSans*; do
            [ -L "$f" ] && rm -f "$f"
        done
        sync_font_substitutes Tahoma
        sync_metric_fonts Tahoma
        return 0
    fi
    [ -n "$live_exe_unix" ] && fonts_dir="${live_exe_unix%/Program/*}/Resources/Fonts"
    if [ "$mode" = auto ]; then
        [ -d "$fonts_dir" ] || return 0
        for f in "$fonts_dir"/AbletonSans*.ttf; do
            [ -e "$f" ] || continue
            ln -sf "$f" "$winfonts/${f##*/}"
            linked=1
        done
        [ "$linked" -eq 1 ] || return 0
        # Ableton Sans Small is the complete family (Regular/Bold/Italic) cut for UI
        # sizes; plain Ableton Sans ships as Light only in current Live 12.
        if [ -e "$winfonts/AbletonSansSmall-Regular.ttf" ]; then
            family="Ableton Sans Small"
        else
            family="Ableton Sans"
        fi
    else
        family="$mode"
    fi
    sync_font_substitutes "$family"
    sync_metric_fonts "$family"
}

# Mirror the host light/dark scheme into the prefix before each launch: Live's "Follow system"
# theme reads AppsUseLightTheme, which a scripted prefix never carries (the early snapshot-based
# installs inherited it). ABLETON_THEME_MODE=auto|dark|light|preserve overrides detection.
if ! pgrep -af "Ableton Live.*\.exe" 2>/dev/null | grep "ProgramData" >/dev/null; then
    # Sourced outside the auto branch: the topbar color detection below wants the lib
    # even when ABLETON_THEME_MODE pins the scheme.
    theme_lib="$HOME/.local/share/ableton-wine/detect-theme.sh"
    [ -r "$theme_lib" ] || theme_lib="$WINE_ROOT/share/ableton-wine/scripts/detect-theme.sh"
    [ -r "$theme_lib" ] && . "$theme_lib"
    theme_mode="${ABLETON_THEME_MODE:-auto}"
    if [ "$theme_mode" = auto ]; then
        theme_mode=preserve
        if declare -F ableton_detect_theme >/dev/null 2>&1; then
            host_scheme="$(ableton_detect_theme)" || host_scheme=""
            case "$host_scheme" in dark|light) theme_mode="$host_scheme" ;; esac
        fi
    fi
    case "$theme_mode" in dark) want_light=0 ;; light) want_light=1 ;; *) want_light="" ;; esac
    if [ -n "$want_light" ]; then
        # Current value straight from the registry file (no wineserver spin-up when unchanged).
        cur_light="$(awk '/^\[Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Themes\\\\Personalize\]/{f=1;next} /^\[/{f=0} f&&/"AppsUseLightTheme"=dword:/{gsub(/.*dword:/,""); gsub(/\r/,""); print; exit}' "$WINEPREFIX/user.reg" 2>/dev/null || true)"
        if [ "${cur_light:-absent}" != "0000000$want_light" ]; then
            echo "ableton-live: host scheme is $theme_mode — setting the prefix theme to match" >&2
            "$WINE_ROOT/bin/wine" reg add 'HKCU\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize' /v AppsUseLightTheme /t REG_DWORD /d "$want_light" /f >/dev/null 2>&1 9>&-
        fi
        # Unified top bar (issue #32): live (the default) colors the bar and menus
        # with Live's active theme so the chrome continues Live's own surface;
        # system inherits the host titlebar colors instead (KDE header colors, or
        # the GNOME header-bar constants for the scheme); "#RRGGBB #RRGGBB" forces
        # bar and text; preserve keeps the plain scheme colors of old.
        topbar=""; menu_bg=""; sel_bg=""; sel_fg=""
        case "${ABLETON_TOPBAR_MODE:-live}" in
            preserve) ;;
            live)   resolve_live_topbar || detect_system_topbar ;;
            system) detect_system_topbar ;;
            \#*)
                if ! topbar="$(parse_topbar_override "$ABLETON_TOPBAR_MODE")"; then
                    echo "ableton-live: cannot parse ABLETON_TOPBAR_MODE '$ABLETON_TOPBAR_MODE' (want '#RRGGBB #RRGGBB') — following the Live theme instead" >&2
                    resolve_live_topbar || detect_system_topbar
                fi ;;
            *)
                echo "ableton-live: ABLETON_TOPBAR_MODE must be live, system, preserve, or '#RRGGBB #RRGGBB' — following the Live theme instead" >&2
                resolve_live_topbar || detect_system_topbar ;;
        esac
        if [ -n "$topbar" ]; then
            sync_win32_colors "$theme_mode" "${topbar%%|*}" "${topbar##*|}" "$menu_bg" "$sel_bg" "$sel_fg"
            ensure_flat_menu
        else
            sync_win32_colors "$theme_mode"
        fi
    fi
    sync_ui_font
fi

# Audio: PipeASIO -> PipeWire (native client, no JACK layer). Defaults live in
# ~/.config/pipeasio/config.ini (seeded by setup-prefix.sh); PIPEASIO_* variables
# override per launch — raise PIPEASIO_PREFERRED_BUFFERSIZE to 512 if crackles.

require_live() {
    [ -n "$EXE" ] && return 0
    echo "ableton-live: no Ableton Live installation found in $WINEPREFIX" >&2
    echo "ableton-live: put your ableton_live*.zip (any edition) in ~/Proprietary and rerun the setup (.run installer or setup-prefix.sh), or install Live manually — see the README" >&2
    exit 1
}

# Bring-up done — drop the single-instance lock so exec'ing wine cannot inherit fd 9.
exec 9>&-

run=(wine)
# The probe fires wherever rtprio rights exist — setup-realtime.sh grants them,
# but some distributions (CachyOS among them) grant them out of the box, so RR
# can be active without any opt-in here. SCHED_RR covers the whole process, GUI
# threads included; ABLETON_RT=off exists for A/B runs and low-core machines
# where that is a net loss. See notes/ABLETON-WINE-RT-SCHEDULING.md.
if [ "${ABLETON_RT:-on}" != off ] && command -v chrt >/dev/null 2>&1 \
    && chrt -r 10 true >/dev/null 2>&1; then
    run=(chrt -r 10 wine)
fi

# Ableton Link bridge (optional): if jack_link is installed but not running
# (e.g. the jack-link.service user unit is disabled), start it under PipeWire's
# JACK layer so the Link session is anchored before Live launches; daemon mode
# logs to ~/.log/jack_link/. See notes/ABLETON-WINE-LINK.md.
if command -v jack_link >/dev/null 2>&1 && command -v pw-jack >/dev/null 2>&1 \
    && ! pgrep -x jack_link >/dev/null 2>&1; then
    pw-jack jack_link --daemon || echo "ableton-live: jack_link failed to start" >&2
fi

# Follow Live-theme changes while it runs (see theme_watch_loop above). Spawned
# after the launch lock is closed, fully detached; a no-op when the helper exe
# is not installed or another watcher already holds the prefix's watch lock.
if [ "${ABLETON_TOPBAR_MODE:-live}" = live ] && [ -n "$EXE" ] && [ -n "${want_light:-}" ]; then
    ( theme_watch_loop ) </dev/null >/dev/null 2>&1 &
    disown
fi

if [ -n "${ABLETON_VDESK:-}" ]; then
    require_live
    exec "${run[@]}" explorer "/desktop=AbletonLive,${ABLETON_VDESK}" "$EXE"
elif [ "$#" -gt 0 ]; then
    # ableton:// URLs, .auz license files, .als sets from the file manager
    exec "${run[@]}" start "$@"
else
    require_live
    exec "${run[@]}" "$EXE"
fi
